{
  "title": "cg-button-click-animation_",
  "code": {
    "index.html": "<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>button click animation | @mukta</title>\n    <link rel=\"stylesheet\" href=\"styles.css\" />\n    <script src=\"https://unpkg.com/@phosphor-icons/web\"></script>\n  </head>\n  <body>\n    <div class=\"copy\">\n      <p>\n        In a future not too distant, <br />\n        mukta forged a button drawer effect. <br />\n        Design ethos / inspo by <br />\n        x @kaihenthoiwane\n      </p>\n    </div>\n    <div class=\"btn\">\n      <div class=\"send\">\n        <i class=\"ph ph-paper-plane-right\"></i>\n      </div>\n      <div class=\"links\">\n        <div class=\"link\" id=\"active\">\n          <div class=\"link-content\">\n            <a href=\"#\">\n              <i class=\"ph ph-sparkle\"></i> &nbsp; Mute DM and let AI reply\n            </a>\n          </div>\n        </div>\n        <div class=\"link\">\n          <div class=\"link-content\">\n            <a href=\"#\">\n              <i class=\"ph ph-paper-plane-right\"></i> &nbsp; Reply Normally\n            </a>\n          </div>\n        </div>\n      </div>\n    </div>\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js\"></script>\n    <script>\n      document.addEventListener(\"DOMContentLoaded\", function () {\n        const btn = document.querySelector(\".btn\");\n        const sendIcon = document.querySelector(\".send\");\n        const links = document.querySelector(\".links\");\n\n        links.style.display = \"none\";\n        const closedDimensions = {\n          width: btn.offsetWidth,\n          height: btn.offsetHeight,\n        };\n\n        links.style.display = \"block\";\n        const openDimensions = {\n          width: btn.offsetWidth,\n          height: btn.offsetHeight,\n        };\n\n        gsap.set(links, { autoAlpha: 0 });\n        gsap.set(sendIcon, { autoAlpha: 1 });\n        btn.style.width = `${closedDimensions.width}px`;\n        btn.style.height = `${closedDimensions.height}px`;\n\n        let isOpen = false;\n\n        const toggleMenu = () => {\n          const timelineSettings = isOpen\n            ? {\n                btnSize: closedDimensions,\n                alpha1: 0,\n                alpha2: 1,\n                scaleValue: 1,\n                marginTop: 0,\n              }\n            : {\n                btnSize: openDimensions,\n                alpha1: 1,\n                alpha2: 0,\n                scaleValue: 0,\n                marginTop: -btn.offsetHeight / 6,\n              };\n\n          const tl = gsap.timeline();\n          tl.to(btn, {\n            duration: 0.75,\n            width: `${timelineSettings.btnSize.width}px`,\n            height: timelineSettings.btnSize.height,\n            ease: \"elastic.out\",\n          })\n            .to(\n              sendIcon,\n              {\n                duration: 0.125,\n                autoAlpha: timelineSettings.alpha2,\n                scale: timelineSettings.scaleValue,\n                marginTop: timelineSettings.marginTop,\n              },\n              0\n            )\n            .to(\n              links,\n              {\n                duration: 0.2,\n                autoAlpha: timelineSettings.alpha1,\n                delay: isOpen ? -0.2 : 0.125,\n              },\n              0\n            );\n\n          isOpen = !isOpen;\n        };\n\n        btn.addEventListener(\"click\", toggleMenu);\n        links.querySelector(\".link a\").forEach((link) => {\n          link.addEventListener(\"click\", (e) => {\n            e.preventDefault();\n            if (isOpen) toggleMenu();\n          });\n        });\n      });\n    </script>\n  </body>\n</html>\n",
    "styles.css": ":root {\n  --color-border: rgba(255, 255, 255, 0.2);\n  --color-link: #a4a4a4;\n  --color-btn-grad-1: rgba(10, 9, 16, 0.5);\n  --color-btn-grad-2: rgba(29, 29, 29, 0.5);\n}\n\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nhtml,\nbody {\n  width: 100vw;\n  height: 100vh;\n  overflow: hidden;\n  background: url(./bg.jpg) no-repeat 50% 50%;\n  background-size: cover;\n  font-family: \"SF Pro Display\";\n}\n\np {\n  margin: 2rem;\n  color: #fff;\n  text-transform: uppercase;\n  font-family: \"PP Supply Mono\";\n  font-weight: 400;\n  color: gray;\n}\n\na {\n  text-decoration: none;\n  color: var(--color-link);\n  pointer-events: none;\n}\n\n.btn {\n  position: fixed;\n  bottom: 0;\n  right: 0;\n  margin: 2em;\n  width: max-content;\n  padding: 0.75rem 1.25rem;\n  backdrop-filter: blur(5px);\n  border: 1px solid var(--color-border);\n  border-radius: 1rem;\n  color: #fff;\n  background: linear-gradient(\n    0deg,\n    var(--color-btn-grad-1) 0%,\n    var(--color-btn-grad-2) 100%\n  );\n  cursor: pointer;\n}\n\n.send {\n  color: #fff;\n  opacity: 1;\n  display: block;\n}\n\n.link {\n  width: 100%;\n  border-radius: 0.75rem;\n  padding: 0.5rem 1rem;\n  margin: 0.5rem 0;\n  cursor: pointer;\n  overflow: hidden;\n}\n\n.link-content {\n  white-space: nowrap;\n}\n\n.link#active {\n  background: #fff;\n}\n\n.link#active a {\n  color: #000;\n}\n\n.links {\n  opacity: 0;\n  display: none;\n}\n"
  }
}