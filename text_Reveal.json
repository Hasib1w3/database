[
  {
    "title": "Cinematic Text Block Reveal Animation",
    "description": "This project is a modern, editorial-style landing page concept that features a sophisticated \"Block Reveal\" typography effect. As users navigate the site using Lenis smooth scrolling, text content is unveiled line-by-line via a dynamic sliding mask (colored block).",
    "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Block Reveal Text Animation</title>\n    \n    <!-- Dependencies (GSAP, ScrollTrigger, SplitType for text splitting, Lenis for smooth scroll) -->\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js\"></script>\n    <script src=\"https://unpkg.com/split-type\"></script>\n    <script src=\"https://cdn.jsdelivr.net/gh/studio-freight/lenis@1.0.29/bundled/lenis.min.js\"></script>\n\n    <style>\n        /* \n           =========================\n           GLOBAL CSS VARIABLES \n           =========================\n        */\n        :root {\n            --tone-100: #000000;\n            --tone-200: #222222;\n            --tone-300: #5b5c57;\n            --tone-400: #e3e4d8;\n            --tone-500: #fe0100; /* Red accent */\n            --font-main: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n        }\n\n        /* \n           =========================\n           RESET & BASE STYLES \n           =========================\n        */\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: var(--font-main);\n            background-color: var(--tone-400);\n            color: var(--tone-100);\n            max-width: 100vw;\n            overflow-x: hidden;\n            /* Allow lenis to handle scroll */\n        }\n\n        /* \n           =========================\n           NAVIGATION \n           =========================\n        */\n        nav {\n            position: fixed;\n            width: 100%;\n            padding: 2rem;\n            display: flex;\n            justify-content: space-between;\n            mix-blend-mode: difference;\n            color: #fff; /* White for difference mode */\n            z-index: 999;\n            top: 0;\n            left: 0;\n        }\n\n        nav p {\n            font-size: 1.5rem;\n            font-weight: 500;\n            text-transform: uppercase;\n        }\n\n        /* \n           =========================\n           SECTION STYLING \n           =========================\n        */\n        section {\n            position: relative;\n            width: 100%;\n            height: 100vh; /* Fallback */\n            height: 100svh;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            overflow: hidden;\n            padding: 2rem;\n        }\n\n        .section-bg {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            z-index: -1;\n        }\n\n        img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            display: block;\n        }\n\n        /* \n           =========================\n           TYPOGRAPHY STYLING \n           =========================\n        */\n        h1, p {\n            text-transform: uppercase;\n            font-weight: 700; /* Making it bold/editorial */\n            line-height: 1; /* Tight line height from tutorial */\n        }\n\n        section h1 {\n            font-size: 6rem;\n            letter-spacing: -0.1rem;\n            width: 75%;\n            color: var(--tone-100);\n        }\n\n        section p {\n            font-size: 3rem;\n            letter-spacing: -0.025rem;\n            width: 60%;\n            color: var(--tone-100);\n        }\n\n        /* Color variations for specific sections based on class context */\n        .intro h1, .services h1, .outro h1 {\n            color: var(--tone-500); /* Red text */\n        }\n\n        .about p, .cta p {\n            font-size: 1.5rem;\n            font-weight: 500;\n            color: var(--tone-200); /* Darker Grey */\n            width: 50%;\n            text-align: left;\n            line-height: 1.2;\n        }\n\n        /* Responsive */\n        @media (max-width: 1000px) {\n            section h1 { font-size: 3rem; width: 100%; }\n            section p { font-size: 1.5rem; width: 100%; }\n            .about p, .cta p { width: 90%; }\n        }\n\n        /* \n           =========================\n           ANIMATION UTILITY CLASSES \n           =========================\n           These imitate what the React logic builds in the DOM\n        */\n        \n        /* 1. Wrapper for each line */\n        .line-wrapper {\n            position: relative;\n            overflow: hidden;\n            display: block; /* Essential for masking */\n            width: max-content; /* Hug the text content */\n        }\n\n        /* 2. The block that slides over */\n        .block-revealer {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 101%; /* Slight overlap to prevent gaps */\n            height: 100%;\n            pointer-events: none;\n            z-index: 2;\n            transform-origin: left center;\n            transform: scaleX(0); /* Start hidden */\n            will-change: transform;\n        }\n\n        /* 3. Ensure the text elements are ready for animation */\n        /* Initially we want text invisible, handled by JS settings */\n        [data-copy-wrapper] {\n            /* Basic setup to ensuring lines break correctly */\n        }\n\n    </style>\n</head>\n<body>\n\n    <nav>\n        <p>Static House</p>\n        <p>Menu</p>\n    </nav>\n\n    <!-- SECTION 1: INTRO (Red H1) -->\n    <!-- Custom attr: data-copy-wrapper initiates the logic. \n         data-block-color sets the swipe color -->\n    <section class=\"intro\">\n        <div class=\"section-bg\">\n            <img src=\"https://images.unsplash.com/photo-1595131838520-22c6b3260c67?q=80&w=2670&auto=format&fit=crop\" alt=\"Interior\">\n        </div>\n        <div data-copy-wrapper data-block-color=\"#fe0100\">\n            <h1>Framed in tungsten and shadows, every shot holds its own deliberate tension.</h1>\n        </div>\n    </section>\n\n    <!-- SECTION 2: ABOUT (Small Paragraph) -->\n    <section class=\"about\">\n        <div data-copy-wrapper data-block-color=\"#000000\">\n            <p>\n                This is cinematography in its raw form with practical lamps, soft falloff, \n                and the presence of grain that fills each corner of the frame. \n                Every room functions as a set and every posture becomes a composition.\n                Light moves across furniture and faces, shaping scenes with a natural sense of depth.\n            </p>\n        </div>\n    </section>\n\n    <!-- SECTION 3: IMAGE BANNER -->\n    <section class=\"banner\">\n        <div class=\"section-bg\">\n            <img src=\"https://images.unsplash.com/photo-1513694203232-719a280e022f?q=80&w=2669&auto=format&fit=crop\" alt=\"Room\">\n        </div>\n    </section>\n\n    <!-- SECTION 4: SERVICES (Red H1) -->\n    <section class=\"services\">\n        <div data-copy-wrapper data-block-color=\"#fe0100\">\n            <h1>Still frames with bold contrast and lighting choices that embrace imperfection.</h1>\n        </div>\n    </section>\n\n    <!-- SECTION 5: IMAGE BANNER 2 -->\n    <section class=\"banner\">\n        <div class=\"section-bg\">\n            <img src=\"https://images.unsplash.com/photo-1512918760513-95f1929c3d71?q=80&w=2672&auto=format&fit=crop\" alt=\"Vintage\">\n        </div>\n    </section>\n\n    <!-- SECTION 6: CTA (Small Paragraph) -->\n    <section class=\"cta\">\n        <div data-copy-wrapper data-block-color=\"#000000\">\n            <p>\n                The camera settles into long takes and patient movement. Colors stay \n                unrefined and shadows turn into texture. The image waits for action instead of chasing it. \n                Every frame forms a clear visual language built through restraint.\n            </p>\n        </div>\n    </section>\n\n    <!-- SECTION 7: OUTRO (Red H1) -->\n    <section class=\"outro\">\n        <div class=\"section-bg\">\n            <img src=\"https://images.unsplash.com/photo-1560185007-cde436f6a4d0?q=80&w=2670&auto=format&fit=crop\" alt=\"Dark Room\">\n        </div>\n        <div data-copy-wrapper data-block-color=\"#fe0100\">\n            <h1>Cinematography thrives in the details from the grain to the falloff to the glow.</h1>\n        </div>\n    </section>\n\n    <script>\n        // 1. REGISTER PLUGINS\n        gsap.registerPlugin(ScrollTrigger);\n\n        // 2. SETUP SMOOTH SCROLL (LENIS)\n        const lenis = new Lenis();\n        function raf(time) {\n            lenis.raf(time);\n            requestAnimationFrame(raf);\n        }\n        requestAnimationFrame(raf);\n\n        // 3. CORE LOGIC - This replicates the 'Copy.jsx' React component logic\n        \n        function initTextRevealAnimations() {\n            // Find all wrappers defined in HTML\n            const copyWrappers = document.querySelectorAll('[data-copy-wrapper]');\n\n            copyWrappers.forEach((wrapper) => {\n                // Config from attributes\n                const blockColor = wrapper.getAttribute('data-block-color') || '#000';\n                \n                // --- A. SPLIT TEXT ---\n                // Using SplitType (free) instead of GSAP SplitText (Paid)\n                // This targets the H1 or P inside the wrapper\n                const childElements = wrapper.querySelectorAll('h1, p');\n                \n                childElements.forEach(textElement => {\n                    const split = new SplitType(textElement, { types: 'lines' });\n                    \n                    // Arrays to hold our created DOM elements\n                    const lines = split.lines; // Arrays of line elements provided by SplitType\n                    const blocks = []; // We will create these manually\n\n                    // --- B. DOM RE-STRUCTURING ---\n                    // Iterate through every line created by the splitter\n                    lines.forEach((line) => {\n                        // 1. Create a wrapper div for the line (to hide overflow/manage layout)\n                        const lineWrapper = document.createElement('div');\n                        lineWrapper.className = 'line-wrapper';\n\n                        // 2. Wrap the line\n                        // Use insertBefore + appendChild to wrap existing line content\n                        line.parentNode.insertBefore(lineWrapper, line);\n                        lineWrapper.appendChild(line);\n\n                        // 3. Create the Block Revealer Div\n                        const block = document.createElement('div');\n                        block.className = 'block-revealer';\n                        block.style.backgroundColor = blockColor;\n                        \n                        // Append block INSIDE the wrapper, typically over the text\n                        lineWrapper.appendChild(block);\n                        blocks.push(block);\n                    });\n\n                    // --- C. SET INITIAL STATES ---\n                    // We must use GSAP Set to ensure standard CSS doesn't conflict\n                    gsap.set(lines, { opacity: 0 }); \n                    gsap.set(blocks, { scaleX: 0, transformOrigin: \"left center\" });\n\n                    // --- D. BUILD ANIMATION TIMELINE ---\n                    const tl = gsap.timeline({\n                        scrollTrigger: {\n                            trigger: wrapper,\n                            start: \"top 80%\", // Triggers when top of element hits 80% of viewport height\n                            toggleActions: \"play none none none\"\n                        }\n                    });\n\n                    // Logic from video:\n                    // 1. Scale X block 0 -> 1 (cover text)\n                    // 2. Make text visible\n                    // 3. Scale X block 1 -> 0 (reveal text, anchored right)\n                    \n                    // We iterate carefully to apply Stagger\n                    // To do complex stagger with separate elements (block vs text) in one timeline logic\n                    // matching the \"createBlockRevealAnimation\" function in video\n                    \n                    lines.forEach((line, index) => {\n                        const block = blocks[index];\n                        // Calculate staggered delay manually for individual control if needed, \n                        // or chain them in timeline. \n                        \n                        // NOTE: To exactly replicate the \"forEach\" logic in the React hook:\n                        \n                        // Phase 1: Block enters (wipes right)\n                        tl.to(block, {\n                            scaleX: 10,\n                            duration: 0.7,\n                            ease: \"power4.inOut\",\n                            transformOrigin: \"left center\"\n                        }, index * 0.1); // Stagger based on index\n\n                        // Phase 2: Toggle Text Opacity (Instant) - overlaps slightly with block wipe\n                        // Usually happens around halfway through the block animation\n                        tl.to(line, {\n                            opacity: 1,\n                            duration: 0.01 // effectively instant\n                        }, index * 0.15 + 0.35);\n\n                        // Phase 3: Block leaves (wipes away to right)\n                        tl.to(block, {\n                            scaleX: 0,\n                            duration: 0.75,\n                            ease: \"power4.inOut\",\n                            transformOrigin: \"right center\" // Crucial switch: grow from left, shrink to right\n                        }, index * 0.15 + 0.35); // Start mid-way of entrance\n                    });\n                });\n            });\n        }\n\n        // Initialize when DOM is ready\n        document.addEventListener(\"DOMContentLoaded\", () => {\n            // Need a slight delay to ensure fonts render before splitting\n            // or use document.fonts.ready (modern browsers)\n            document.fonts.ready.then(() => {\n                initTextRevealAnimations();\n                // Refresh ScrollTrigger to ensure calculations are correct after splits\n                ScrollTrigger.refresh();\n            });\n        });\n\n    </script>\n</body>\n</html>"
  }
]