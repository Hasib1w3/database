[
  {
    "title": "Cinematic Text Block Reveal Animation",
    "description": "This project is a modern, editorial-style landing page concept that features a sophisticated \"Block Reveal\" typography effect. As users navigate the site using Lenis smooth scrolling, text content is unveiled line-by-line via a dynamic sliding mask (colored block).",
    "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Block Reveal Text Animation</title>\n    \n    <!-- Dependencies (GSAP, ScrollTrigger, SplitType for text splitting, Lenis for smooth scroll) -->\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js\"></script>\n    <script src=\"https://unpkg.com/split-type\"></script>\n    <script src=\"https://cdn.jsdelivr.net/gh/studio-freight/lenis@1.0.29/bundled/lenis.min.js\"></script>\n\n    <style>\n        /* \n           =========================\n           GLOBAL CSS VARIABLES \n           =========================\n        */\n        :root {\n            --tone-100: #000000;\n            --tone-200: #222222;\n            --tone-300: #5b5c57;\n            --tone-400: #e3e4d8;\n            --tone-500: #fe0100; /* Red accent */\n            --font-main: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n        }\n\n        /* \n           =========================\n           RESET & BASE STYLES \n           =========================\n        */\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: var(--font-main);\n            background-color: var(--tone-400);\n            color: var(--tone-100);\n            max-width: 100vw;\n            overflow-x: hidden;\n            /* Allow lenis to handle scroll */\n        }\n\n        /* \n           =========================\n           NAVIGATION \n           =========================\n        */\n        nav {\n            position: fixed;\n            width: 100%;\n            padding: 2rem;\n            display: flex;\n            justify-content: space-between;\n            mix-blend-mode: difference;\n            color: #fff; /* White for difference mode */\n            z-index: 999;\n            top: 0;\n            left: 0;\n        }\n\n        nav p {\n            font-size: 1.5rem;\n            font-weight: 500;\n            text-transform: uppercase;\n        }\n\n        /* \n           =========================\n           SECTION STYLING \n           =========================\n        */\n        section {\n            position: relative;\n            width: 100%;\n            height: 100vh; /* Fallback */\n            height: 100svh;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            overflow: hidden;\n            padding: 2rem;\n        }\n\n        .section-bg {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            z-index: -1;\n        }\n\n        img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            display: block;\n        }\n\n        /* \n           =========================\n           TYPOGRAPHY STYLING \n           =========================\n        */\n        h1, p {\n            text-transform: uppercase;\n            font-weight: 700; /* Making it bold/editorial */\n            line-height: 1; /* Tight line height from tutorial */\n        }\n\n        section h1 {\n            font-size: 6rem;\n            letter-spacing: -0.1rem;\n            width: 75%;\n            color: var(--tone-100);\n        }\n\n        section p {\n            font-size: 3rem;\n            letter-spacing: -0.025rem;\n            width: 60%;\n            color: var(--tone-100);\n        }\n\n        /* Color variations for specific sections based on class context */\n        .intro h1, .services h1, .outro h1 {\n            color: var(--tone-500); /* Red text */\n        }\n\n        .about p, .cta p {\n            font-size: 1.5rem;\n            font-weight: 500;\n            color: var(--tone-200); /* Darker Grey */\n            width: 50%;\n            text-align: left;\n            line-height: 1.2;\n        }\n\n        /* Responsive */\n        @media (max-width: 1000px) {\n            section h1 { font-size: 3rem; width: 100%; }\n            section p { font-size: 1.5rem; width: 100%; }\n            .about p, .cta p { width: 90%; }\n        }\n\n        /* \n           =========================\n           ANIMATION UTILITY CLASSES \n           =========================\n           These imitate what the React logic builds in the DOM\n        */\n        \n        /* 1. Wrapper for each line */\n        .line-wrapper {\n            position: relative;\n            overflow: hidden;\n            display: block; /* Essential for masking */\n            width: max-content; /* Hug the text content */\n        }\n\n        /* 2. The block that slides over */\n        .block-revealer {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 101%; /* Slight overlap to prevent gaps */\n            height: 100%;\n            pointer-events: none;\n            z-index: 2;\n            transform-origin: left center;\n            transform: scaleX(0); /* Start hidden */\n            will-change: transform;\n        }\n\n        /* 3. Ensure the text elements are ready for animation */\n        /* Initially we want text invisible, handled by JS settings */\n        [data-copy-wrapper] {\n            /* Basic setup to ensuring lines break correctly */\n        }\n\n    </style>\n</head>\n<body>\n\n    <nav>\n        <p>Static House</p>\n        <p>Menu</p>\n    </nav>\n\n    <!-- SECTION 1: INTRO (Red H1) -->\n    <!-- Custom attr: data-copy-wrapper initiates the logic. \n         data-block-color sets the swipe color -->\n    <section class=\"intro\">\n        <div class=\"section-bg\">\n            <img src=\"https://images.unsplash.com/photo-1595131838520-22c6b3260c67?q=80&w=2670&auto=format&fit=crop\" alt=\"Interior\">\n        </div>\n        <div data-copy-wrapper data-block-color=\"#fe0100\">\n            <h1>Framed in tungsten and shadows, every shot holds its own deliberate tension.</h1>\n        </div>\n    </section>\n\n    <!-- SECTION 2: ABOUT (Small Paragraph) -->\n    <section class=\"about\">\n        <div data-copy-wrapper data-block-color=\"#000000\">\n            <p>\n                This is cinematography in its raw form with practical lamps, soft falloff, \n                and the presence of grain that fills each corner of the frame. \n                Every room functions as a set and every posture becomes a composition.\n                Light moves across furniture and faces, shaping scenes with a natural sense of depth.\n            </p>\n        </div>\n    </section>\n\n    <!-- SECTION 3: IMAGE BANNER -->\n    <section class=\"banner\">\n        <div class=\"section-bg\">\n            <img src=\"https://images.unsplash.com/photo-1513694203232-719a280e022f?q=80&w=2669&auto=format&fit=crop\" alt=\"Room\">\n        </div>\n    </section>\n\n    <!-- SECTION 4: SERVICES (Red H1) -->\n    <section class=\"services\">\n        <div data-copy-wrapper data-block-color=\"#fe0100\">\n            <h1>Still frames with bold contrast and lighting choices that embrace imperfection.</h1>\n        </div>\n    </section>\n\n    <!-- SECTION 5: IMAGE BANNER 2 -->\n    <section class=\"banner\">\n        <div class=\"section-bg\">\n            <img src=\"https://images.unsplash.com/photo-1512918760513-95f1929c3d71?q=80&w=2672&auto=format&fit=crop\" alt=\"Vintage\">\n        </div>\n    </section>\n\n    <!-- SECTION 6: CTA (Small Paragraph) -->\n    <section class=\"cta\">\n        <div data-copy-wrapper data-block-color=\"#000000\">\n            <p>\n                The camera settles into long takes and patient movement. Colors stay \n                unrefined and shadows turn into texture. The image waits for action instead of chasing it. \n                Every frame forms a clear visual language built through restraint.\n            </p>\n        </div>\n    </section>\n\n    <!-- SECTION 7: OUTRO (Red H1) -->\n    <section class=\"outro\">\n        <div class=\"section-bg\">\n            <img src=\"https://images.unsplash.com/photo-1560185007-cde436f6a4d0?q=80&w=2670&auto=format&fit=crop\" alt=\"Dark Room\">\n        </div>\n        <div data-copy-wrapper data-block-color=\"#fe0100\">\n            <h1>Cinematography thrives in the details from the grain to the falloff to the glow.</h1>\n        </div>\n    </section>\n\n    <script>\n        // 1. REGISTER PLUGINS\n        gsap.registerPlugin(ScrollTrigger);\n\n        // 2. SETUP SMOOTH SCROLL (LENIS)\n        const lenis = new Lenis();\n        function raf(time) {\n            lenis.raf(time);\n            requestAnimationFrame(raf);\n        }\n        requestAnimationFrame(raf);\n\n        // 3. CORE LOGIC - This replicates the 'Copy.jsx' React component logic\n        \n        function initTextRevealAnimations() {\n            // Find all wrappers defined in HTML\n            const copyWrappers = document.querySelectorAll('[data-copy-wrapper]');\n\n            copyWrappers.forEach((wrapper) => {\n                // Config from attributes\n                const blockColor = wrapper.getAttribute('data-block-color') || '#000';\n                \n                // --- A. SPLIT TEXT ---\n                // Using SplitType (free) instead of GSAP SplitText (Paid)\n                // This targets the H1 or P inside the wrapper\n                const childElements = wrapper.querySelectorAll('h1, p');\n                \n                childElements.forEach(textElement => {\n                    const split = new SplitType(textElement, { types: 'lines' });\n                    \n                    // Arrays to hold our created DOM elements\n                    const lines = split.lines; // Arrays of line elements provided by SplitType\n                    const blocks = []; // We will create these manually\n\n                    // --- B. DOM RE-STRUCTURING ---\n                    // Iterate through every line created by the splitter\n                    lines.forEach((line) => {\n                        // 1. Create a wrapper div for the line (to hide overflow/manage layout)\n                        const lineWrapper = document.createElement('div');\n                        lineWrapper.className = 'line-wrapper';\n\n                        // 2. Wrap the line\n                        // Use insertBefore + appendChild to wrap existing line content\n                        line.parentNode.insertBefore(lineWrapper, line);\n                        lineWrapper.appendChild(line);\n\n                        // 3. Create the Block Revealer Div\n                        const block = document.createElement('div');\n                        block.className = 'block-revealer';\n                        block.style.backgroundColor = blockColor;\n                        \n                        // Append block INSIDE the wrapper, typically over the text\n                        lineWrapper.appendChild(block);\n                        blocks.push(block);\n                    });\n\n                    // --- C. SET INITIAL STATES ---\n                    // We must use GSAP Set to ensure standard CSS doesn't conflict\n                    gsap.set(lines, { opacity: 0 }); \n                    gsap.set(blocks, { scaleX: 0, transformOrigin: \"left center\" });\n\n                    // --- D. BUILD ANIMATION TIMELINE ---\n                    const tl = gsap.timeline({\n                        scrollTrigger: {\n                            trigger: wrapper,\n                            start: \"top 80%\", // Triggers when top of element hits 80% of viewport height\n                            toggleActions: \"play none none none\"\n                        }\n                    });\n\n                    // Logic from video:\n                    // 1. Scale X block 0 -> 1 (cover text)\n                    // 2. Make text visible\n                    // 3. Scale X block 1 -> 0 (reveal text, anchored right)\n                    \n                    // We iterate carefully to apply Stagger\n                    // To do complex stagger with separate elements (block vs text) in one timeline logic\n                    // matching the \"createBlockRevealAnimation\" function in video\n                    \n                    lines.forEach((line, index) => {\n                        const block = blocks[index];\n                        // Calculate staggered delay manually for individual control if needed, \n                        // or chain them in timeline. \n                        \n                        // NOTE: To exactly replicate the \"forEach\" logic in the React hook:\n                        \n                        // Phase 1: Block enters (wipes right)\n                        tl.to(block, {\n                            scaleX: 10,\n                            duration: 0.7,\n                            ease: \"power4.inOut\",\n                            transformOrigin: \"left center\"\n                        }, index * 0.1); // Stagger based on index\n\n                        // Phase 2: Toggle Text Opacity (Instant) - overlaps slightly with block wipe\n                        // Usually happens around halfway through the block animation\n                        tl.to(line, {\n                            opacity: 1,\n                            duration: 0.01 // effectively instant\n                        }, index * 0.15 + 0.35);\n\n                        // Phase 3: Block leaves (wipes away to right)\n                        tl.to(block, {\n                            scaleX: 0,\n                            duration: 0.75,\n                            ease: \"power4.inOut\",\n                            transformOrigin: \"right center\" // Crucial switch: grow from left, shrink to right\n                        }, index * 0.15 + 0.35); // Start mid-way of entrance\n                    });\n                });\n            });\n        }\n\n        // Initialize when DOM is ready\n        document.addEventListener(\"DOMContentLoaded\", () => {\n            // Need a slight delay to ensure fonts render before splitting\n            // or use document.fonts.ready (modern browsers)\n            document.fonts.ready.then(() => {\n                initTextRevealAnimations();\n                // Refresh ScrollTrigger to ensure calculations are correct after splits\n                ScrollTrigger.refresh();\n            });\n        });\n\n    </script>\n</body>\n</html>"
  },
  {
    "title": "Kinetic Scroll Typography & Responsive Velocity Marquee",
    "description": "This project creates a highly interactive hero section found in high-end creative portfolios. It features a \"sticky\" scroll experience where the viewport stays pinned while typography transforms word-by-word based on scroll progress. Additionally, an infinite marquee at the bottom reacts to the scroll velocity, accelerating when the user scrolls faster.",
    "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Scroll-Based Text Transitions | CodeGrid Rebuild</title>\n    \n    <!-- Fonts -->\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Geist+Mono:wght@100..900&family=Manrope:wght@200..800&display=swap\" rel=\"stylesheet\">\n\n    <!-- CSS -->\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        /* Hide Scrollbar */\n        ::-webkit-scrollbar {\n            display: none;\n        }\n\n        body {\n            font-family: \"Manrope\", sans-serif;\n            background-color: #0f0f0f;\n            color: #fff;\n            overflow-x: hidden;\n        }\n\n        /* \n           The hero holds the visual content and is fixed. \n           The .container provides the scrollable height.\n        */\n        .container {\n            position: relative;\n            width: 100%;\n            height: 600vh; /* Determines duration of animation */\n        }\n\n        .hero {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100dvh;\n            overflow: hidden;\n        }\n\n        /* Navigation */\n        nav {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            padding: 2rem;\n            display: flex;\n            justify-content: space-between;\n            z-index: 10;\n            mix-blend-mode: difference;\n        }\n\n        nav p {\n            text-transform: uppercase;\n            font-family: \"Geist Mono\", monospace;\n            font-size: 0.8rem;\n            line-height: 1;\n        }\n\n        /* Main Copy Section */\n        .about-copy {\n            position: absolute;\n            top: 50%;\n            left: 0;\n            transform: translateY(-50%);\n            width: 100%;\n            padding: 2rem;\n            display: flex;\n            justify-content: space-between;\n            gap: 4rem;\n        }\n\n        .copy-block {\n            flex: 1;\n            display: flex; /* Helps align content */\n        }\n\n        /* Paragraph Styling */\n        .copy-block p {\n            font-size: 1.75rem;\n            font-weight: 450;\n            letter-spacing: -0.025rem;\n            line-height: 1.2;\n            /* We initially hide everything; GSAP handles reveal */\n        }\n\n        /* CSS for the split words helper */\n        .word-wrapper {\n            display: inline-block;\n            overflow: hidden;\n            vertical-align: top;\n            padding-bottom: 0.2em; \n            margin-bottom: -0.2em; \n        }\n        \n        .word-inner {\n            display: inline-block;\n            will-change: transform;\n            /* Starts pushed down out of view */\n            transform: translateY(100%); \n        }\n\n        /* Scroll Indicator */\n        .scroll-indicator {\n            position: absolute;\n            top: 2rem;\n            right: 2rem;\n            width: 10rem;\n            height: 0.1rem;\n            background-color: #2f2f2f;\n            z-index: 20;\n        }\n\n        .scroll-indicator::after {\n            content: \"\";\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background-color: #fff;\n            transform-origin: left;\n            /* Custom property updated by JS */\n            transform: scaleX(var(--progress, 0));\n            will-change: transform;\n        }\n\n        /* Infinite Marquee */\n        .marquee {\n            position: absolute;\n            bottom: 2rem;\n            left: 0;\n            width: 100%;\n            height: 7.5rem; /* ~120px */\n            overflow: hidden;\n            display: flex;\n            align-items: center;\n        }\n\n        .marquee-track {\n            display: flex;\n            gap: 0.75rem;\n            will-change: transform;\n            /* Important for JS calculation */\n            padding-left: 0.75rem; \n        }\n\n        .marquee-item {\n            width: 10rem;\n            height: 6rem;\n            border-radius: 0.25rem;\n            overflow: hidden;\n            flex-shrink: 0;\n            position: relative;\n            background: #222;\n        }\n\n        .marquee-item img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            display: block;\n        }\n\n        /* Responsive */\n        @media (max-width: 1000px) {\n            nav {\n                flex-direction: column-reverse;\n                align-items: flex-start;\n                gap: 0.75rem;\n            }\n            \n            .about-copy {\n                flex-direction: column;\n                gap: 2rem;\n                top: 20rem; /* Push down to avoid nav intersection on mobile */\n                transform: none;\n                height: auto;\n            }\n\n            .copy-block p {\n                font-size: 1.25rem;\n            }\n            \n            /* On mobile, we keep only one column layout, simpler animation setup \n               The JS logic naturally stacks, but visually: */\n            .copy-block {\n                width: 100%;\n            }\n        }\n    </style>\n</head>\n<body>\n\n    <!-- Structure -->\n    <nav>\n        <p>/ CG191125</p>\n        <p>EXPERIMENT_507</p>\n        \n        <!-- Indicator Wrapper -->\n        <div class=\"scroll-indicator\"></div>\n    </nav>\n\n    <!-- Invisible Scroll Height -->\n    <div class=\"container\"></div>\n\n    <!-- Fixed Content -->\n    <section class=\"hero\">\n        <div class=\"about-copy\">\n            \n            <!-- BLOCK 1 (Start visible via JS logic) -->\n            <div class=\"copy-block\" id=\"block-1\">\n                <p>I work in portrait photography with a focus on light, tone, and quiet expression. My approach is patient and intentional.</p>\n            </div>\n\n            <!-- BLOCK 2 -->\n            <div class=\"copy-block\" id=\"block-2\">\n                <p>I try to build images that feel honest, with enough breathing room for personality to settle into the frame.</p>\n            </div>\n\n            <!-- BLOCK 3 -->\n            <div class=\"copy-block\" id=\"block-3\">\n                <p>The final images aim to capture the shift between who they are and become the moment the shutter falls still.</p>\n            </div>\n\n        </div>\n\n        <div class=\"marquee\">\n            <div class=\"marquee-track\">\n                <!-- Using placeholder images for demonstration pixel perfect recreation of functionality -->\n                <div class=\"marquee-item\"><img src=\"https://picsum.photos/200/120?random=1\" alt=\"img\"></div>\n                <div class=\"marquee-item\"><img src=\"https://picsum.photos/200/120?random=2\" alt=\"img\"></div>\n                <div class=\"marquee-item\"><img src=\"https://picsum.photos/200/120?random=3\" alt=\"img\"></div>\n                <div class=\"marquee-item\"><img src=\"https://picsum.photos/200/120?random=4\" alt=\"img\"></div>\n                <div class=\"marquee-item\"><img src=\"https://picsum.photos/200/120?random=5\" alt=\"img\"></div>\n                <div class=\"marquee-item\"><img src=\"https://picsum.photos/200/120?random=6\" alt=\"img\"></div>\n                <div class=\"marquee-item\"><img src=\"https://picsum.photos/200/120?random=7\" alt=\"img\"></div>\n                <div class=\"marquee-item\"><img src=\"https://picsum.photos/200/120?random=8\" alt=\"img\"></div>\n                <div class=\"marquee-item\"><img src=\"https://picsum.photos/200/120?random=9\" alt=\"img\"></div>\n                <div class=\"marquee-item\"><img src=\"https://picsum.photos/200/120?random=10\" alt=\"img\"></div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Dependencies -->\n    <!-- Lenis for Smooth Scroll -->\n    <script src=\"https://unpkg.com/lenis@1.1.13/dist/lenis.min.js\"></script> \n    <!-- GSAP Core -->\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js\"></script>\n    <!-- ScrollTrigger -->\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js\"></script>\n\n    <!-- Main Logic -->\n    <script>\n        document.addEventListener(\"DOMContentLoaded\", () => {\n            \n            // --- 1. CONFIG & SETUP ---\n            \n            // Register GSAP Plugin\n            gsap.registerPlugin(ScrollTrigger);\n\n            // Initialize Lenis (Smooth Scroll)\n            const lenis = new Lenis({\n                lerp: 0.1,\n                smoothWheel: true,\n            });\n\n            // Global velocity tracker for Marquee\n            let targetVelocity = 0; \n\n            // Sync Lenis scroll with Marquee velocity logic\n            lenis.on('scroll', (e) => {\n                // e.velocity captures the scroll speed. We scale it slightly.\n                // Math.abs() needed? Tutorial logic usually uses raw velocity to detect direction, \n                // but for simple speed calc usually Abs. However, based on video math:\n                // If standard implementation:\n                targetVelocity = e.velocity * 0.05; \n                ScrollTrigger.update();\n            });\n\n            // Integrate Lenis into GSAP Ticker for performance\n            gsap.ticker.add((time) => {\n                lenis.raf(time * 1000);\n            });\n            \n            // Disable lag smoothing for instant feedback during heavy scroll\n            gsap.ticker.lagSmoothing(0);\n\n\n            // --- 2. TEXT TRANSITION LOGIC (Custom Free Split Implementation) ---\n\n            /**\n             * Since SplitText is paid, we recreate the \"Word Mask\" effect.\n             * Returns an object: { elements: [array of wrapper divs], words: [array of inner text spans] }\n             */\n            function splitTextFree(selector) {\n                const element = document.querySelector(selector);\n                if(!element) return { words: [] };\n\n                const text = element.innerText;\n                const wordsArray = text.split(' ');\n                \n                element.innerHTML = ''; // clear original text\n                \n                const createdWords = [];\n\n                wordsArray.forEach((word) => {\n                    // Outer Wrapper (Mask)\n                    const wrapper = document.createElement('span');\n                    wrapper.classList.add('word-wrapper');\n                    \n                    // Inner Span (Actual Text to animate)\n                    const inner = document.createElement('span');\n                    inner.classList.add('word-inner');\n                    inner.innerText = word + '\\u00A0'; // Add non-breaking space\n                    \n                    wrapper.appendChild(inner);\n                    element.appendChild(wrapper);\n                    \n                    createdWords.push(inner);\n                });\n\n                return { words: createdWords };\n            }\n\n            // Get our 3 blocks. Note: The CSS initially puts translateY(100%) on .word-inner\n            const splitInstance1 = splitTextFree('#block-1 p');\n            const splitInstance2 = splitTextFree('#block-2 p');\n            const splitInstance3 = splitTextFree('#block-3 p');\n\n            // Set Initial State:\n            // Block 1 should be visible (0%) initially? Actually, usually, title implies transition relative to scroll.\n            // Let's adhere to the logic: At scroll 0, Block 1 is visible (0%), 2 is hidden (100%), 3 is hidden (100%).\n            \n            // NOTE: .word-inner has transform: translateY(100%) in CSS by default.\n            // So we explicitly set Block 1 to 0 initially.\n            gsap.set(splitInstance1.words, { yPercent: 0 }); \n            // Block 2 & 3 stay at CSS default (100%)\n\n            // --- 3. HELPER FUNCTIONS ---\n\n            const overlapCount = 3; // How many words overlap in movement\n\n            // Logic to calculate progress of a single word based on overall phrase progress\n            const getWordProgress = (phaseProgress, index, totalWords) => {\n                const totalLength = 1 + overlapCount / totalWords;\n                const scale = 1 / Math.min(totalLength, (1 + (totalWords -1) / totalWords + overlapCount / totalWords));\n                \n                // When does this word start moving?\n                const startTime = (index / totalWords) * scale;\n                // When does it stop?\n                const endTime = startTime + (overlapCount / totalWords) * scale;\n                // Duration of this specific word's movement\n                const duration = endTime - startTime;\n\n                if (phaseProgress <= startTime) return 0;\n                if (phaseProgress >= endTime) return 1;\n                return (phaseProgress - startTime) / duration;\n            }\n\n            /**\n             * Animates between an outgoing block and an incoming block.\n             * phaseProgress: 0 to 1\n             */\n            const animateBlock = (outInstance, inInstance, phaseProgress) => {\n                \n                // OUTGOING BLOCK (Moves from 0% up to -100%)\n                if(outInstance && outInstance.words.length > 0) {\n                    outInstance.words.forEach((word, i) => {\n                        // \"Inverting\" calculation because we are scrolling down -> hiding.\n                        // However, simpler to visualize phase progress directly mapping.\n                        // Logic from context: Hiding previous involves staggering out.\n                        const progress = getWordProgress(phaseProgress, i, outInstance.words.length);\n                        // Moves UP: 0 -> -100\n                        gsap.set(word, { yPercent: -progress * 100 });\n                    });\n                }\n\n                // INCOMING BLOCK (Moves from 100% up to 0%)\n                if(inInstance && inInstance.words.length > 0) {\n                    inInstance.words.forEach((word, i) => {\n                        // Normal stagger in. \n                        const progress = getWordProgress(phaseProgress, i, inInstance.words.length);\n                        // Moves UP: 100 -> 0. \n                        // Equation: 100 - (progress * 100)\n                        gsap.set(word, { yPercent: 100 - (progress * 100) });\n                    });\n                }\n            }\n\n\n            // --- 4. SCROLLTRIGGER MAIN LOOP ---\n\n            ScrollTrigger.create({\n                trigger: '.container',\n                start: 'top top',\n                end: 'bottom bottom',\n                scrub: true, // We will manually handle via onUpdate for manual calculation consistency\n                onUpdate: (self) => {\n                    const progress = self.progress; // 0 to 1 across 600vh\n                    \n                    // Update Top Scroll Indicator\n                    document.documentElement.style.setProperty('--progress', progress);\n\n                    /* \n                       Logic: We have 3 blocks, so 2 Transitions.\n                       Transition 1: Block 1 -> Block 2 (occurs 0.0 - 0.5)\n                       Transition 2: Block 2 -> Block 3 (occurs 0.5 - 1.0)\n                    */\n\n                    if(progress <= 0.5) {\n                        // PHASE 1: Normalizing 0-0.5 to 0-1\n                        const phase1 = progress / 0.5;\n                        \n                        // We must ensure Block 3 is fully pushed down/hidden if we scrub back up quickly\n                        gsap.set(splitInstance3.words, { yPercent: 100 }); \n\n                        // Run Animation\n                        animateBlock(splitInstance1, splitInstance2, phase1);\n\n                    } else {\n                        // PHASE 2: Normalizing 0.5-1.0 to 0-1\n                        const phase2 = (progress - 0.5) / 0.5;\n\n                        // Ensure Block 1 is fully pushed up/hidden\n                        gsap.set(splitInstance1.words, { yPercent: -100 });\n\n                        // Run Animation\n                        animateBlock(splitInstance2, splitInstance3, phase2);\n                    }\n                }\n            });\n\n\n            // --- 5. INFINITE MARQUEE WITH PHYSICS ---\n\n            const marqueeTrack = document.querySelector('.marquee-track');\n            const marqueeItems = gsap.utils.toArray('.marquee-item');\n            \n            // Clone items to fill screen + buffer for infinity\n            // Assuming simplified clone logic for this demo container\n            marqueeItems.forEach(item => {\n                const clone = item.cloneNode(true);\n                marqueeTrack.appendChild(clone);\n            });\n            // Double clone for safety on wide screens\n            marqueeItems.forEach(item => {\n                const clone = item.cloneNode(true);\n                marqueeTrack.appendChild(clone);\n            });\n\n            let marqueePos = 0;\n            let smoothVelocity = 0;\n            const baseSpeed = 0.5; // Constant drift speed\n\n            gsap.ticker.add(() => {\n                // Create inertia/smoothness by lerping raw targetVelocity\n                // Formula: Current + (Target - Current) * Factor\n                smoothVelocity += (targetVelocity - smoothVelocity) * 0.1;\n\n                // Final speed calculation: Base speed + amplified scroll influence\n                const currentSpeed = baseSpeed + (smoothVelocity * 2);\n\n                marqueePos -= currentSpeed;\n\n                // Reset logic for infinity\n                // We use scrollWidth / 3 because we have Original + Clone + Clone\n                // But for robust implementation based on provided CSS sizes:\n                const totalWidth = marqueeTrack.scrollWidth;\n                \n                // Wrap logic roughly:\n                if(marqueePos <= -totalWidth / 3) {\n                    marqueePos = 0;\n                } else if(marqueePos > 0) {\n                    // Just in case we reversed, though logic here implies always left-movement base + absolute velocity impact\n                    marqueePos = -totalWidth / 3; \n                }\n\n                // Move logic with some GSAP decay on the scroll variable\n                // Friction for the velocity var to return to 0 when user stops scrolling\n                targetVelocity *= 0.9;\n\n                // Apply transform\n                gsap.set(marqueeTrack, { x: marqueePos });\n            });\n\n        });\n    </script>\n</body>\n</html>"
  }
