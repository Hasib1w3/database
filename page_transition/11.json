{
  "title": "make sure the page transition to and from have same code logiic set properly",
  "description": "make sure the page transition to and from have same code logiic set properly",
  "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Barba Page Wipe Transition</title>\n\n    <!-- CSS (Lenis for smooth scrolling) -->\n    <link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1.3.17/dist/lenis.css\">\n\n    <style>\n        /* -----------------------------------------\n           CORE STYLES\n           ----------------------------------------- */\n        body {\n            margin: 0;\n            padding: 0;\n            font-family: sans-serif;\n            background-color: #f0f0f0;\n            overflow-x: hidden;\n        }\n\n        /* Nav Config */\n        nav {\n            position: fixed;\n            top: 20px;\n            left: 20px;\n            z-index: 10;\n            display: flex;\n            gap: 15px;\n            background: white;\n            padding: 10px 20px;\n            border-radius: 30px;\n        }\n        nav a {\n            text-decoration: none;\n            color: black;\n            font-weight: bold;\n        }\n\n        /* Section Layout */\n        section {\n            height: 100vh;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            font-size: 3rem;\n            text-align: center;\n        }\n\n        /* -----------------------------------------\n           TRANSITION OVERLAY STYLES\n           (The \"Wipe\" Animation Layer)\n           ----------------------------------------- */\n        \n        .transition {\n            /* Sits on top of everything, waiting to animate */\n            z-index: 9999;\n            pointer-events: none;\n            position: fixed;\n            inset: 0; /* Cover full screen */\n            overflow: clip;\n            height: 100vh;\n            width: 100vw;\n        }\n\n        .transition__panels {\n            width: 100%;\n            height: 100%;\n            display: flex;\n            position: absolute;\n            top: 0;\n            left: 0;\n        }\n\n        /* The vertical columns that fall down */\n        .transition__panel {\n            background-color: #2a2a2a; /* Dark Grey color for wipe */\n            width: 100%;\n            height: 100%;\n            position: relative;\n            /* STARTS ABOVE SCREEN (-100% top) */\n            top: -100%; \n        }\n\n        /* Decorative lines on the columns */\n        .transition__lines {\n            opacity: 0.1;\n            width: 100%;\n            height: 100%;\n            display: flex;\n            position: absolute;\n            top: 0;\n            left: 0;\n            pointer-events: none;\n        }\n\n        .transition__line {\n            border-right: 1px solid #fff;\n            width: 100%;\n            height: 100%;\n        }\n\n        .transition__line.is--last {\n            border-right: none;\n        }\n    </style>\n</head>\n\n<body data-barba=\"wrapper\">\n\n    <!-- \n        TRANSITION WRAPPER \n        This div is \"fixed\" over the screen. Barba animates the panels inside it.\n    -->\n    <div data-transition-wrap class=\"transition\">\n        <div class=\"transition__panels\">\n            <div data-transition-column class=\"transition__panel\"></div>\n            <div data-transition-column class=\"transition__panel\"></div>\n            <div data-transition-column class=\"transition__panel\"></div>\n            <div data-transition-column class=\"transition__panel\"></div>\n            <div data-transition-column class=\"transition__panel\"></div>\n        </div>\n        <div class=\"transition__lines\">\n            <div class=\"transition__line\"></div>\n            <div class=\"transition__line\"></div>\n            <div class=\"transition__line\"></div>\n            <div class=\"transition__line\"></div>\n            <div class=\"transition__line is--last\"></div>\n        </div>\n    </div>\n\n    <!-- MAIN PAGE CONTAINER -->\n    <main data-barba=\"container\" data-barba-namespace=\"home\">\n        \n        <nav>\n            <a href=\"index.html\">Home</a>\n            <a href=\"about.html\">About</a>\n        </nav>\n\n        <section style=\"background-color: #e0e0e0;\">\n            <h1>Barba Wipe Transition</h1>\n            <p style=\"font-size:1.5rem\">Click a link above to trigger wipe</p>\n        </section>\n\n        <section style=\"background-color: #d4d4d4;\">\n            Section 2\n        </section>\n        \n        <section style=\"background-color: #c0c0c0;\">\n            Footer\n        </section>\n\n    </main>\n\n    <!-- SCRIPTS -->\n    <script src=\"https://cdn.jsdelivr.net/npm/@barba/core@2.10.3/dist/barba.umd.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/lenis@1.3.17/dist/lenis.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/gsap.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/CustomEase.min.js\"></script>\n\n    <script>\n        // -----------------------------------------\n        // 1. SETUP & UTILS\n        // -----------------------------------------\n        gsap.registerPlugin(CustomEase);\n\n        if ('scrollRestoration' in history) {\n            history.scrollRestoration = \"manual\";\n        }\n\n        let lenis = null;\n        let nextPage = document;\n        \n        // Setup Lenis (Smooth Scroll)\n        const initLenis = () => {\n            if (lenis) return;\n            lenis = new Lenis({ lerp: 0.165, wheelMultiplier: 1.25 });\n            gsap.ticker.add((time) => lenis.raf(time * 1000));\n            gsap.ticker.lagSmoothing(0);\n        };\n        \n        const resetPage = (container) => {\n            if(lenis) {\n                lenis.scrollTo(0, { immediate: true });\n                lenis.start();\n            } else {\n                window.scrollTo(0,0);\n            }\n        };\n\n        const reducedMotion = window.matchMedia(\"(prefers-reduced-motion: reduce)\").matches;\n        CustomEase.create(\"osmo\", \"0.625, 0.05, 0, 1\");\n        gsap.defaults({ ease: \"osmo\", duration: 0.6 });\n\n        // -----------------------------------------\n        // 2. THE ANIMATION LOGIC (WIPE)\n        // -----------------------------------------\n\n        // ANIMATION: LEAVE (Current page disappears)\n        function runPageLeaveAnimation(current, next) {\n            const transitionWrap = document.querySelector(\"[data-transition-wrap]\");\n            const transitionColumns = transitionWrap.querySelectorAll(\"[data-transition-column]\");\n            \n            const tl = gsap.timeline({\n                onComplete: () => { current.remove() } // Cleanup old html\n            });\n\n            // Step 1: Hide the NEXT page so it doesn't flash before the wipe finishes\n            tl.set(next, { autoAlpha: 0 }, 0);\n\n            // Step 2: Animate Columns DOWN to cover screen\n            // Start: yPercent: 0 (This is -100% relative to screen because of CSS top:-100%)\n            // End: yPercent: 100 (Moves down exactly 100% height, fully covering viewport)\n            tl.fromTo(transitionColumns, {\n                yPercent: 0\n            },{\n                yPercent: 100, \n                duration: 0.8,\n                stagger: { each: 0.05, from: \"end\" } // Wave Effect: Right -> Left\n            }, 0);\n\n            return tl;\n        }\n\n        // ANIMATION: ENTER (New page appears)\n        function runPageEnterAnimation(next){\n            const transitionWrap = document.querySelector(\"[data-transition-wrap]\");\n            const transitionColumns = transitionWrap.querySelectorAll(\"[data-transition-column]\");\n            \n            const tl = gsap.timeline();\n\n            tl.add(\"startEnter\", 0.6); // Slightly delayed sync\n\n            // Step 3: Show new page content underneath the columns (currently hidden)\n            tl.set(next, { autoAlpha: 1 }, \"startEnter\");\n\n            // Step 4: Move Columns DOWN AGAIN to reveal new page\n            // Start: yPercent 100 (Covering screen)\n            // End: yPercent 200 (Off screen bottom)\n            tl.to(transitionColumns, {\n                yPercent: 200,\n                duration: 0.8,\n                stagger: 0.05, // Wave Effect: Left -> Right\n            }, \"startEnter\");\n\n            // Reset logic when done\n            tl.add(\"pageReady\");\n            tl.call(resetPage, [next], \"pageReady\");\n\n            return new Promise(resolve => tl.call(resolve, null, \"pageReady\"));\n        }\n\n        function runPageOnceAnimation(next) {\n            // First Load (No wipe, just reset)\n            initLenis();\n            resetPage(next);\n        }\n\n        // -----------------------------------------\n        // 3. BARBA INIT\n        // -----------------------------------------\n\n        barba.hooks.beforeEnter(data => {\n            // Fix positioning of next container so they overlap during transition\n            gsap.set(data.next.container, {\n                position: \"fixed\", top: 0, left: 0, width: \"100%\"\n            });\n            if(lenis) lenis.stop();\n        });\n\n        barba.hooks.afterEnter(data => {\n            gsap.set(data.next.container, { clearProps: \"position,top,left,width\" });\n            if(lenis) lenis.resize();\n        });\n\n        barba.init({\n            debug: true,\n            sync: true, // IMPORTANT: Allows Leave and Enter timelines to overlap\n            transitions: [\n                {\n                    name: \"wipe-transition\",\n                    once(data) {\n                        return runPageOnceAnimation(data.next.container);\n                    },\n                    leave(data) {\n                        return runPageLeaveAnimation(data.current.container, data.next.container);\n                    },\n                    enter(data) {\n                        return runPageEnterAnimation(data.next.container);\n                    }\n                }\n            ]\n        });\n    </script>\n</body>\n</html>"
}