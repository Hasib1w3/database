{
  "title": "make sure the page transition to and from have same code logiic set properly",
  "description": "make sure the page transition to and from have same code logiic set properly",
  "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Fixed 3D Transition</title>\n\n<!-- EXTERNAL LIBS -->\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1.3.17/dist/lenis.css\">\n\n<style>\n    /* BASIC SETUP TO SEE THE TRANSITION */\n    body { margin: 0; background-color: #1a1a1a; font-family: sans-serif; overflow-x: hidden; }\n    \n    /* NAV (Keep Z-Index HIGH) */\n    nav { position: fixed; top: 20px; left: 20px; z-index: 9999; display: flex; gap: 20px; }\n    nav a { color: white; background: #000; padding: 10px 20px; border-radius: 20px; text-decoration: none; font-weight: bold; }\n    \n    /* PAGE CONTAINER */\n    main { min-height: 100vh; width: 100%; position: relative; background: #fff; padding-top: 100px; }\n    \n    /* PAGE COLORS (Must differ to see swipe) */\n    [data-barba-namespace=\"home\"] main { background: #e0e0e0; }\n    [data-barba-namespace=\"about\"] main { background: #b0b0b0; }\n    \n    section { max-width: 900px; margin: 0 auto; padding: 40px; }\n    h1 { font-size: 5rem; margin-bottom: 20px; }\n    .block { height: 400px; width: 100%; background: #333; margin-top: 50px; }\n\n    /* Helper for 3D */\n    .page-transition__wrapper { pointer-events: none; }\n</style>\n</head>\n\n<body data-barba=\"wrapper\">\n  \n    <nav>\n        <a href=\"index.html\">Index</a>\n        <a href=\"about.html\">About</a>\n    </nav>\n\n    <main data-barba=\"container\" data-barba-namespace=\"home\">\n        <section>\n            <h1>Working 3D Transition</h1>\n            <p>We removed the conflicting reset call from the Enter function. The movement now plays fully.</p>\n            <div class=\"block\"></div>\n        </section>\n    </main>\n\n<script src=\"https://cdn.jsdelivr.net/npm/@barba/core@2.10.3/dist/barba.umd.min.js\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/lenis@1.3.17/dist/lenis.min.js\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/gsap.min.js\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/CustomEase.min.js\"></script>\n\n<script>\n// -----------------------------------------\n// SETUP\n// -----------------------------------------\ngsap.registerPlugin(CustomEase);\nhistory.scrollRestoration = \"manual\";\n\nlet lenis = new Lenis({ lerp: 0.165, wheelMultiplier: 1.25 });\ngsap.ticker.add((t) => lenis.raf(t * 1000));\ngsap.ticker.lagSmoothing(0);\n\n// KEEP EXACT EASING\nCustomEase.create(\"osmo\", \"0.625, 0.05, 0, 1\");\ngsap.defaults({ ease: \"osmo\", duration: 0.6 });\n\nconst hasLenis = true;\n\n// HELPER: PREPARE 3D DOM\nfunction prepareForTransition(parent, current, next){\n  const wrapper = document.createElement(\"div\");\n  wrapper.className = \"page-transition__wrapper\";\n  parent.insertBefore(wrapper, current);\n  wrapper.appendChild(current);\n\n  const scrollY = window.scrollY || 0;\n  window.scrollTo(0, 0);\n\n  // Parent 3D\n  gsap.set(parent, {\n    perspective: \"100vw\", transformStyle: \"preserve-3d\", overflow: \"hidden\", height: \"100vh\"\n  });\n\n  // Old Page Wrapper\n  gsap.set(wrapper, {\n    position: \"fixed\", top: 0, left: 0, width: \"100%\", height: \"100vh\",\n    overflow: \"hidden\", zIndex: 2, transformStyle: \"preserve-3d\",\n    willChange: \"transform\", clipPath: \"rect(0% 100% 100% 0% round 0em)\"\n  });\n  \n  // Freeze Scroll\n  gsap.set(current, { position: \"absolute\", top: -scrollY, left: 0, width: \"100%\" });\n  \n  // Next Page Setup (Off Right, Deep Z)\n  gsap.set(next, {\n    position: \"fixed\", top: 0, left: 0, width: \"100%\", height: \"100vh\",\n    overflow: \"hidden\", zIndex: 1, transformStyle: \"preserve-3d\",\n    willChange: \"transform\", backfaceVisibility: \"hidden\",\n    xPercent: 175,  // Exact from your code\n    z: \"-100vw\",    // Exact from your code\n    autoAlpha: 1,\n    clipPath: \"rect(0% 100% 100% 0% round 1.5em)\"\n  });  \n  \n  return { wrapper };\n}\n\n// -----------------------------------------\n// ANIMATION FUNCTIONS\n// -----------------------------------------\n\nfunction resetPage(container) {\n    gsap.set(container, { clearProps: \"all\" });\n    lenis.start();\n    lenis.resize();\n}\n\nfunction runPageOnceAnimation(next) {\n    resetPage(next);\n}\n\n// THIS FUNCTION HANDLES EVERYTHING (Movement + Cleanup)\nfunction runPageLeaveAnimation(current, next) {\n    const parent = current.parentElement || document.body;\n    const { wrapper } = prepareForTransition(parent, current, next);\n    \n    // Cleanup happens ONLY when movement finishes\n    const tl = gsap.timeline({\n        onComplete: () => {\n            wrapper.remove();\n            gsap.set(parent, { clearProps: \"perspective,transformStyle,overflow,height\" });\n            gsap.set(next, { clearProps: \"all\" });\n            resetPage(next); // Ensure final scroll reset\n        }\n    });\n    \n    // 1. Move OLD back\n    tl.to(wrapper, { \n        z: \"-100vw\", duration: 0.9, \n        clipPath: \"rect(0% 100% 100% 0% round 1.5em)\" \n    }, 0);\n    \n    // 2. Move OLD left\n    tl.to(wrapper, { xPercent: -175, duration: 1, overwrite: \"auto\" }, 0.25);\n    \n    // 3. Move NEW center (Same time as step 2)\n    tl.to(next, { xPercent: 0, duration: 1, overwrite: \"auto\" }, \"<\");\n    \n    // 4. Move NEW forward (Cleanup z-depth)\n    tl.to(next, { \n        z: 0, duration: 0.9, overwrite: \"auto\", \n        clipPath: \"rect(0% 100% 100% 0% round 0em)\" \n    }, \">-=0.4\");\n    \n    return tl;\n}\n\n// !!! IMPORTANT FIX IS HERE !!!\n// This function used to call 'resetPage' immediately. Now it does NOT.\nfunction runPageEnterAnimation(next) {\n    const tl = gsap.timeline();\n    // We just ensure opacity is 1. The movement is handled by LEAVE above.\n    tl.set(next, { autoAlpha: 1 }); \n    return tl;\n}\n\n\n// -----------------------------------------\n// INIT BARBA\n// -----------------------------------------\nbarba.hooks.beforeEnter(data => {\n    // Basic setup, but `prepareForTransition` handles strict layout\n    if(lenis) lenis.stop();\n});\n\nbarba.init({\n    debug: true,\n    transitions: [{\n        name: \"3d-move\",\n        sync: true, // Must be true for overlapping animation\n        once(data) { runPageOnceAnimation(data.next.container); },\n        leave(data) { return runPageLeaveAnimation(data.current.container, data.next.container); },\n        enter(data) { return runPageEnterAnimation(data.next.container); }\n    }]\n});\n\n</script>\n</body>\n</html>"
}