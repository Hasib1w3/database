{
  "title": "make sure the page transition to and from have same code logiic set properly",
  "description": "make sure the page transition to and from have same code logiic set properly",
  "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Osmo Page Name Wipe</title>\n\n<!-- EXTERNAL CSS -->\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1.3.17/dist/lenis.css\">\n\n<style>\n    /* -------------------------------------------\n       1. BASIC PAGE STYLES\n       ------------------------------------------- */\n    body {\n        margin: 0;\n        background-color: #f0f0f0;\n        font-family: Arial, sans-serif;\n        overflow-x: hidden;\n    }\n\n    /* Make sure main has color so it doesn't look broken */\n    main {\n        width: 100%;\n        min-height: 100vh;\n        background: #fff;\n        position: relative;\n        padding-top: 100px; /* Spacer for fixed Nav */\n    }\n\n    /* Page colors */\n    [data-page-name=\"Home\"] main { background: #eeeeee; }\n    [data-page-name=\"About\"] main { background: #cccccc; }\n\n    /* Nav stays ON TOP of content, but BELOW transition (z:50 vs z:9999) */\n    nav {\n        position: fixed; top: 20px; left: 20px; z-index: 50;\n        background: white; padding: 15px 30px; border-radius: 40px;\n        box-shadow: 0 5px 15px rgba(0,0,0,0.1);\n        display: flex; gap: 20px;\n    }\n    nav a { text-decoration: none; color: black; font-weight: bold; font-size: 14px; text-transform: uppercase; }\n\n    section { max-width: 900px; margin: 0 auto; padding: 40px; }\n    h1 { font-size: 4rem; margin-bottom: 20px; }\n    p { font-size: 1.25rem; line-height: 1.6; margin-bottom: 20px; color: #555; }\n    .img-box { width: 100%; height: 300px; background: #999; margin-top: 30px; }\n\n\n    /* -------------------------------------------\n       2. TRANSITION STYLES (The Green Curtain)\n       ------------------------------------------- */\n    \n    .transition {\n        /* EXTREME Z-INDEX to ensure it's on top */\n        z-index: 9999; \n        pointer-events: none;\n        position: fixed; /* Fixed covers viewport even if scrolled */\n        inset: 0;\n        width: 100%;\n        height: 100vh;\n    }\n\n    .transition__panel {\n        background-color: #30463e; /* The Green Color */\n        width: 100%;\n        height: 100%;\n        position: absolute;\n        top: 100%; /* Start BELOW the screen */\n        left: 0;\n        display: flex;\n        justify-content: center;\n        align-items: center;\n        /* Default visible/invisible state handled by GSAP */\n        opacity: 0; \n        visibility: hidden; \n    }\n\n    .transition__label {\n        color: #cbe88a; /* Light Green Text */\n        text-transform: uppercase;\n        font-family: monospace;\n        font-size: 2.5em;\n        /* Hidden initially, GSAP reveals it */\n        opacity: 0; \n        visibility: hidden;\n    }\n\n</style>\n</head>\n\n<body data-barba=\"wrapper\">\n\n    <!-- \n      TRANSITION ELEMENTS \n      Must exist outside the data-barba=\"container\"\n    -->\n    <div data-transition-wrap class=\"transition\">\n        <div data-transition-panel class=\"transition__panel\">\n            <span data-transition-label class=\"transition__label\">\n                <span>[ </span>\n                <!-- Text changes dynamically via JS -->\n                <span data-transition-label-text>Loading...</span>\n                <span> ]</span>\n            </span>\n        </div>\n    </div>\n\n\n    <!-- \n       CONTENT CONTAINER \n       CHANGE data-page-name=\"About\" in your second file! \n    -->\n    <main data-barba=\"container\" data-page-name=\"Home\">\n        \n        <!-- Navigation inside Container -->\n        <nav>\n            <a href=\"index.html\">Home</a>\n            <a href=\"about.html\">About (Page 2)</a>\n        </nav>\n\n        <section>\n            <h1>Page Name Wipe</h1>\n            <p>We have forced animations enabled (bypassing reduced motion settings) and set Z-Index to 9999.</p>\n            <div class=\"img-box\"></div>\n        </section>\n\n    </main>\n\n    <!-- JS LIBS -->\n    <script src=\"https://cdn.jsdelivr.net/npm/@barba/core@2.10.3/dist/barba.umd.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/lenis@1.3.17/dist/lenis.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/gsap.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/CustomEase.min.js\"></script>\n\n    <!-- JS LOGIC -->\n    <script>\n    \n    // --- 1. SETUP ---\n    gsap.registerPlugin(CustomEase);\n    \n    // Fix: Force Manual scroll to handle resets ourselves\n    history.scrollRestoration = \"manual\";\n\n    // Setup Lenis (Smooth Scroll)\n    let lenis = new Lenis({ lerp: 0.165, wheelMultiplier: 1.25 });\n    gsap.ticker.add((time) => lenis.raf(time * 1000));\n    gsap.ticker.lagSmoothing(0);\n\n    // Custom Easing\n    CustomEase.create(\"osmo\", \"0.625, 0.05, 0, 1\");\n    gsap.defaults({ ease: \"osmo\", duration: 0.8 }); // 0.8s default duration\n\n    // FORCE REDUCED MOTION OFF (For debugging visibility)\n    const reducedMotion = false; \n\n    // --- 2. TRANSITION FUNCTIONS ---\n\n    function resetPage(container){\n        window.scrollTo(0, 0);\n        // Clear conflicting GSAP props from the page container\n        gsap.set(container, { clearProps: \"position,top,left,right,y,autoAlpha,transform\" });\n        if(lenis){ lenis.resize(); lenis.start(); }\n    }\n\n    // ANIMATION: LEAVE (Panel Moves Up over current page)\n    function runPageLeaveAnimation(current, next) {\n        // Select elements\n        const transitionWrap = document.querySelector(\"[data-transition-wrap]\");\n        const transitionPanel = transitionWrap.querySelector(\"[data-transition-panel]\");\n        const transitionLabel = transitionWrap.querySelector(\"[data-transition-label]\");\n        const transitionLabelText = transitionWrap.querySelector(\"[data-transition-label-text]\");\n        \n        // Update Label Text (Checks for attribute, falls back to \"Page\")\n        const nextPageName = next.dataset.pageName || \"Page\";\n        transitionLabelText.innerText = nextPageName;\n        \n        const tl = gsap.timeline({\n            onComplete: () => { current.remove(); }\n        });\n        \n        if (reducedMotion) return tl.set(current, { autoAlpha: 0 });\n        \n        // 1. Make Panel Visible (but it's still positioned below screen via CSS top:100%)\n        tl.set(transitionPanel, { autoAlpha: 1, visibility: \"visible\" }, 0);\n        tl.set(next, { autoAlpha: 0 }, 0); // Hide new page\n\n        // 2. Move Panel UP to cover screen\n        // from yPercent: 0 (Below screen) to yPercent: -100 (Covering screen)\n        tl.fromTo(transitionPanel,{\n            yPercent: 0 \n        },{\n            yPercent: -100, \n            duration: 0.8,\n        }, 0);\n        \n        // 3. Fade In Text Label\n        tl.fromTo(transitionLabel, {\n            autoAlpha: 0, visibility: \"visible\"\n        },{\n            autoAlpha: 1\n        }, \"<+=0.2\");\n        \n        // 4. Parallax current page UP slightly\n        tl.fromTo(current,{\n            y: \"0vh\"\n        },{\n            y: \"-15vh\",\n            duration: 0.8,\n        }, 0);\n        \n        return tl;\n    }\n\n\n    // ANIMATION: ENTER (Panel moves Up away to reveal new page)\n    function runPageEnterAnimation(next){\n        const transitionWrap = document.querySelector(\"[data-transition-wrap]\");\n        const transitionPanel = transitionWrap.querySelector(\"[data-transition-panel]\");\n        const transitionLabel = transitionWrap.querySelector(\"[data-transition-label]\");\n        \n        const tl = gsap.timeline();\n        \n        if (reducedMotion) {\n            tl.set(next, { autoAlpha: 1 });\n            tl.add(\"pageReady\");\n            return new Promise(resolve => tl.call(resolve, null, \"pageReady\"));\n        }  \n        \n        // Add Delay to let user read text (Start moving away at 1.25s)\n        tl.add(\"startEnter\", 1.25);\n        \n        // Make New Page Visible (it's sitting behind the panel)\n        tl.set(next, { autoAlpha: 1 }, \"startEnter\");\n        \n        // 5. Move Panel UP Away from screen\n        // from -100 (Covering) to -200 (Above)\n        tl.fromTo(transitionPanel, {\n            yPercent: -100,\n        },{\n            yPercent: -200, \n            duration: 1,\n            overwrite: \"auto\",\n        }, \"startEnter\");\n        \n        // Hide Panel after it moves away\n        tl.set(transitionPanel, { autoAlpha: 0, visibility: \"hidden\" }, \">\");\n        \n        // Fade Out Label\n        tl.to(transitionLabel, {\n            autoAlpha: 0,\n            duration: 0.4,\n            overwrite: \"auto\",\n        }, \"startEnter+=0.1\");\n        \n        // 6. New Page Rises UP from below (y: 15vh -> 0)\n        tl.fromTo(next, {\n            y: \"15vh\",\n        },{\n            y: \"0vh\",\n            duration: 1,\n            clearProps: \"y\" // Clean up afterwards\n        }, \"startEnter\");\n        \n        // Finalize\n        tl.add(\"pageReady\");\n        tl.call(resetPage, [next], \"pageReady\"); // Calls cleanup\n\n        return new Promise(resolve => {\n            tl.call(resolve, null, \"pageReady\");\n        });\n    }\n\n    // --- 3. BARBA INIT ---\n    \n    // Once: Just reset on load\n    function runPageOnceAnimation(next) {\n        initLenis();\n        resetPage(next);\n    }\n    function initLenis() {\n        if(!lenis) lenis.start();\n    }\n\n\n    barba.hooks.beforeEnter(data => {\n        // Fix: Absolute Position Next Container so it layers correctly\n        gsap.set(data.next.container, { position: \"fixed\", top: 0, left: 0, right: 0, width: \"100%\" });\n        if(lenis) lenis.stop();\n        \n        // Basic theme/active-link swap\n        const links = document.querySelectorAll('nav a');\n        links.forEach(a => {\n            if(data.next.url.path.includes(a.getAttribute('href'))) a.style.textDecoration = \"underline\";\n            else a.style.textDecoration = \"none\";\n        });\n    });\n\n    barba.init({\n        debug: true,\n        timeout: 7000,\n        preventRunning: true,\n        transitions: [\n            {\n                name: \"page-name-wipe\",\n                sync: true, // Enables overlapping timelines\n                \n                once(data) {\n                    return runPageOnceAnimation(data.next.container);\n                },\n                leave(data) {\n                    return runPageLeaveAnimation(data.current.container, data.next.container);\n                },\n                enter(data) {\n                    return runPageEnterAnimation(data.next.container);\n                }\n            }\n        ]\n    });\n\n    </script>\n</body>\n</html>"
}