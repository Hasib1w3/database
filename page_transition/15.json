{
  "title": "GSAP Block Reveal Transition",
  "description": "This file creates a fully functional Single Page Application (SPA) simulation that replicates the \"Pixelated Block Reveal\" transition effect typically seen in advanced Next.js websites.",
  "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>mukta Block Reveal Transition (Vanilla JS)</title>\n    \n    <!-- GSAP CDN -->\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js\"></script>\n\n    <!-- FONTS -->\n    <link href=\"https://fonts.cdnfonts.com/css/schabo\" rel=\"stylesheet\">\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&display=swap\" rel=\"stylesheet\">\n\n    <style>\n        :root {\n            --base-100: #fcfcfc;\n            --base-200: #3f3f3f;\n            --base-300: #0f0f0f;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            background-color: var(--base-200);\n            color: var(--base-100);\n            overflow: hidden; /* Keep transition neat */\n            font-family: 'DM Mono', monospace;\n        }\n\n        /* IMAGES */\n        img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            display: block;\n        }\n\n        /* TEXT STYLES */\n        h1 {\n            text-transform: uppercase;\n            font-family: \"SCHABO\", sans-serif;\n            font-size: clamp(6rem, 15vw, 12rem);\n            font-weight: 500;\n            line-height: 0.9;\n            z-index: 1;\n        }\n\n        /* NAVIGATION */\n        nav {\n            position: fixed;\n            bottom: 5rem;\n            left: 50%;\n            transform: translateX(-50%);\n            display: flex;\n            gap: 0.25rem;\n            z-index: 1000;\n        }\n\n        nav button {\n            text-decoration: none;\n            text-transform: uppercase;\n            color: var(--base-100);\n            font-family: \"DM Mono\", monospace;\n            font-size: 0.8rem;\n            font-weight: 450;\n            line-height: 1;\n            padding: 0.5rem 0.75rem;\n            background-color: var(--base-300);\n            border: none;\n            border-radius: 0.2rem;\n            cursor: pointer;\n            transition: transform 200ms ease-out;\n        }\n\n        nav button:active {\n            transform: scale(0.9);\n        }\n\n        /* SECTIONS / PAGES */\n        /* Since we don't have routing, we stack them and hide inactive ones */\n        .page-container {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100vh;\n            visibility: hidden; /* Hide all by default */\n        }\n\n        .page-container.active {\n            visibility: visible;\n        }\n\n        section {\n            position: relative;\n            width: 100%;\n            height: 100vh;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            overflow: hidden;\n        }\n\n        .section-bg {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            z-index: -1;\n        }\n\n        /* TRANSITION OVERLAY GRID */\n        .transition-grid {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100vw;\n            height: 100vh;\n            pointer-events: none;\n            z-index: 2000;\n            display: block; \n        }\n\n        .transition-block {\n            position: absolute;\n            background-color: var(--base-300);\n            opacity: 0; \n        }\n    </style>\n</head>\n<body>\n\n    <!-- TRANSITION LAYER -->\n    <div id=\"grid-container\" class=\"transition-grid\"></div>\n\n    <!-- NAVIGATION -->\n    <nav>\n        <button onclick=\"goToPage('home')\">Homebase</button>\n        <button onclick=\"goToPage('gateway')\">Gateway</button>\n        <button onclick=\"goToPage('station')\">Station</button>\n        <button onclick=\"goToPage('colony')\">Colony</button>\n    </nav>\n\n    <!-- PAGES CONTENT -->\n    <!-- Page 1: Home -->\n    <div id=\"home\" class=\"page-container active\">\n        <section>\n            <div class=\"section-bg\">\n                <!-- Using placeholder images so code works immediately. \n                     Replace 'src' with local paths like './bg_1.jpg' -->\n                <img src=\"https://images.unsplash.com/photo-1614728853975-69c960f7274f?q=80&w=1920&auto=format&fit=crop\" alt=\"Home Base\">\n            </div>\n            <div class=\"section-header\">\n                <h1>Homebase</h1>\n            </div>\n        </section>\n    </div>\n\n    <!-- Page 2: Gateway -->\n    <div id=\"gateway\" class=\"page-container\">\n        <section>\n            <div class=\"section-bg\">\n                <img src=\"https://images.unsplash.com/photo-1462331940025-496dfbfc7564?q=80&w=1920&auto=format&fit=crop\" alt=\"Gateway\">\n            </div>\n            <div class=\"section-header\">\n                <h1>Gateway</h1>\n            </div>\n        </section>\n    </div>\n\n    <!-- Page 3: Station -->\n    <div id=\"station\" class=\"page-container\">\n        <section>\n            <div class=\"section-bg\">\n                <img src=\"https://images.unsplash.com/photo-1446776811953-644d55495a6f?q=80&w=1920&auto=format&fit=crop\" alt=\"Station\">\n            </div>\n            <div class=\"section-header\">\n                <h1>Station</h1>\n            </div>\n        </section>\n    </div>\n\n    <!-- Page 4: Colony -->\n    <div id=\"colony\" class=\"page-container\">\n        <section>\n            <div class=\"section-bg\">\n                <img src=\"https://images.unsplash.com/photo-1614730341194-75c60740a5d3?q=80&w=1920&auto=format&fit=crop\" alt=\"Colony\">\n            </div>\n            <div class=\"section-header\">\n                <h1>Colony</h1>\n            </div>\n        </section>\n    </div>\n\n    <script>\n        const BLOCK_SIZE = 60;\n        const gridContainer = document.getElementById(\"grid-container\");\n        let blocks = [];\n        let isAnimating = false;\n        let currentPageId = 'home'; // Tracks current visible page\n\n        // 1. Function to create the grid blocks (Pixel Perfect Calculation)\n        function createGrid() {\n            gridContainer.innerHTML = \"\";\n            blocks = [];\n\n            const gridWidth = window.innerWidth;\n            const gridHeight = window.innerHeight;\n\n            const columns = Math.ceil(gridWidth / BLOCK_SIZE);\n            const rows = Math.ceil(gridHeight / BLOCK_SIZE) + 1;\n\n            // Offset calculation to center the grid exactly as per tutorial\n            const offsetx = (gridWidth - columns * BLOCK_SIZE) / 2;\n            const offsety = (gridHeight - rows * BLOCK_SIZE) / 2;\n\n            for (let row = 0; row < rows; row++) {\n                for (let col = 0; col < columns; col++) {\n                    const block = document.createElement(\"div\");\n                    block.className = \"transition-block\";\n                    block.style.width = `${BLOCK_SIZE}px`;\n                    block.style.height = `${BLOCK_SIZE}px`;\n                    block.style.left = `${col * BLOCK_SIZE + offsetx}px`;\n                    block.style.top = `${row * BLOCK_SIZE + offsety}px`;\n\n                    gridContainer.appendChild(block);\n                    blocks.push(block);\n                }\n            }\n        }\n\n        // 2. Build grid on load and resize\n        window.addEventListener(\"resize\", createGrid);\n        // Initial create\n        createGrid();\n\n        // 3. Navigation Function (Replaces next-transition-router logic)\n        function goToPage(targetId) {\n            // Prevent double clicking or clicking same page\n            if (isAnimating || targetId === currentPageId) return;\n            isAnimating = true;\n\n            // --- LEAVE ANIMATION (SCATTER IN) ---\n            gsap.to(blocks, {\n                opacity: 1,\n                duration: 0.05,\n                stagger: {\n                    amount: 0.5,\n                    from: \"random\"\n                },\n                ease: \"power2.inOut\",\n                onComplete: () => {\n                    // 1. Swap DOM Pages (Simulation of routing)\n                    document.getElementById(currentPageId).classList.remove('active');\n                    document.getElementById(targetId).classList.add('active');\n                    currentPageId = targetId;\n\n                    // 2. Reset opacity instantly for the 'reveal' phase (redundant here but ensures safety)\n                    // GSAP will animate from opacity:1 to opacity:0 below.\n                    \n                    // --- ENTER ANIMATION (SCATTER OUT) ---\n                    gsap.to(blocks, {\n                        opacity: 0,\n                        duration: 0.05,\n                        delay: 0.2, // Small pause when screen is full black\n                        stagger: {\n                            amount: 0.5,\n                            from: \"random\"\n                        },\n                        ease: \"power2.inOut\",\n                        onComplete: () => {\n                            isAnimating = false;\n                        }\n                    });\n                }\n            });\n        }\n    </script>\n</body>\n</html>"
}