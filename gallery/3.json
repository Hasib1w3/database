  "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Prototype Studio Scroll Animation</title>\n    \n    <!-- Fonts -->\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap\" rel=\"stylesheet\">\n\n    <!-- CSS -->\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        :root {\n            --bg-color: #141414;\n            --text-active: #ffffff;\n            --text-inactive: #4a4a4a;\n        }\n\n        body {\n            font-family: \"Inter\", sans-serif;\n            background-color: var(--bg-color);\n            color: var(--text-active);\n            overflow-x: hidden; /* Hide horizontal scrollbar */\n        }\n\n        /* Generic Section Styles */\n        section {\n            position: relative;\n            width: 100%;\n            height: 100vh;\n            padding: 2rem;\n            overflow: hidden;\n        }\n\n        .intro, .outro {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            font-size: 1.5rem;\n            color: var(--text-inactive);\n        }\n\n        /* Spotlight Section */\n        .spotlight {\n            /* This is the section that gets pinned */\n        }\n\n        /* Project Index (Top Left) */\n        .project-index {\n            position: absolute;\n            top: 2rem;\n            left: 2rem;\n            height: 200px; /* Limit height for scroll calc */\n            z-index: 10;\n            /* Container setup for animation */\n            overflow: hidden; \n        }\n\n        .project-index h1 {\n            font-size: clamp(3rem, 5vw, 7rem);\n            font-weight: 400;\n            line-height: 1;\n            /* Animation readiness */\n            will-change: transform; \n        }\n\n        /* Project Names (Bottom Right) */\n        .project-names {\n            position: absolute;\n            bottom: 2rem;\n            right: 2rem;\n            display: flex;\n            flex-direction: column;\n            align-items: flex-end;\n            text-align: right;\n            z-index: 10;\n            overflow: hidden;\n            height: 200px; /* Arbitrary constraints for the layout calculations */\n        }\n\n        .project-names p {\n            font-size: 1.5rem;\n            font-weight: 500;\n            line-height: 1.25;\n            color: var(--text-inactive);\n            transition: color 0.3s ease;\n            white-space: nowrap;\n            /* Animation readiness */\n            will-change: transform;\n        }\n\n        /* Images Column (Center) */\n        .project-images {\n            position: absolute;\n            top: 0;\n            left: 50%;\n            transform: translateX(-50%); /* Start perfectly centered */\n            width: 35%; /* Mobile could be 90% via media query */\n            /* Add spacing buffers to start scrolling from outside view */\n            padding: 50vh 0; \n            display: flex;\n            flex-direction: column;\n            gap: 25vh; /* Large gap between images */\n            z-index: 1;\n            will-change: transform;\n        }\n\n        .project-img {\n            width: 100%;\n            aspect-ratio: 16/9;\n            overflow: hidden;\n            opacity: 0.5; /* Default state */\n            transition: opacity 0.3s ease;\n        }\n\n        .project-img img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            display: block;\n        }\n\n        /* Utility */\n        @media (max-width: 1000px) {\n            .project-images {\n                width: calc(100% - 4rem);\n                gap: 25vh;\n            }\n            /* Hide names on small screens or adjust */\n            .project-names p {\n                font-size: 1rem;\n            }\n        }\n    </style>\n</head>\n<body>\n\n    <!-- Intro Section -->\n    <section class=\"intro\">\n        <p>A collection of selected works</p>\n    </section>\n\n    <!-- Main Spotlight (Pinned Section) -->\n    <section class=\"spotlight\">\n        <!-- 1. Index Counter -->\n        <div class=\"project-index\">\n            <!-- Content will be updated by JS initially but structural placeholder here -->\n            <div class=\"index-wrapper\">\n                <h1>01/10</h1>\n            </div>\n        </div>\n\n        <!-- 2. The Moving Images -->\n        <div class=\"project-images\">\n            <!-- 10 Projects -->\n            <div class=\"project-img\"><img src=\"https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?q=80&w=1000&auto=format&fit=crop\" alt=\"Model 1\"></div>\n            <div class=\"project-img\"><img src=\"https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=1000&auto=format&fit=crop\" alt=\"Light\"></div>\n            <div class=\"project-img\"><img src=\"https://images.unsplash.com/photo-1550684848-fac1c5b4e853?q=80&w=1000&auto=format&fit=crop\" alt=\"Interior\"></div>\n            <div class=\"project-img\"><img src=\"https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=1000&auto=format&fit=crop\" alt=\"Shadow\"></div>\n            <div class=\"project-img\"><img src=\"https://images.unsplash.com/photo-1616486338812-3dadae4b4f9d?q=80&w=1000&auto=format&fit=crop\" alt=\"Objects\"></div>\n            <div class=\"project-img\"><img src=\"https://images.unsplash.com/photo-1628143439973-1f92e4722c24?q=80&w=1000&auto=format&fit=crop\" alt=\"Care\"></div>\n            <div class=\"project-img\"><img src=\"https://images.unsplash.com/photo-1542273917363-3b1817f69a2d?q=80&w=1000&auto=format&fit=crop\" alt=\"Forest\"></div>\n            <div class=\"project-img\"><img src=\"https://images.unsplash.com/photo-1605721911519-3dfeb3be25e7?q=80&w=1000&auto=format&fit=crop\" alt=\"Watch\"></div>\n            <div class=\"project-img\"><img src=\"https://images.unsplash.com/photo-1631679706909-1844bbd07221?q=80&w=1000&auto=format&fit=crop\" alt=\"Material\"></div>\n            <div class=\"project-img\"><img src=\"https://images.unsplash.com/photo-1506157786151-b8491531f063?q=80&w=1000&auto=format&fit=crop\" alt=\"Walk\"></div>\n        </div>\n\n        <!-- 3. The Project Names List -->\n        <div class=\"project-names\">\n            <div class=\"names-wrapper\">\n                <p>Human Form Study</p>\n                <p>Interior Light</p>\n                <p>Project 21</p>\n                <p>Shadow Portraits</p>\n                <p>Everyday Objects</p>\n                <p>Unit 07 Care</p>\n                <p>Motion Practice</p>\n                <p>Noonlight Series</p>\n                <p>Material Stillness</p>\n                <p>Quiet Walk</p>\n            </div>\n        </div>\n    </section>\n\n    <!-- Outro Section -->\n    <section class=\"outro\">\n        <p>Scroll complete</p>\n    </section>\n\n    <!-- Libraries -->\n    <!-- Lenis for smooth scrolling -->\n    <script src=\"https://cdn.jsdelivr.net/gh/studio-freight/lenis@1.0.29/bundled/lenis.min.js\"></script>\n    <!-- GSAP Core -->\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js\"></script>\n    <!-- ScrollTrigger Plugin -->\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js\"></script>\n\n    <!-- Animation Logic -->\n    <script type=\"module\">\n        document.addEventListener(\"DOMContentLoaded\", () => {\n            \n            // 1. Initialize Lenis (Smooth Scroll)\n            const lenis = new Lenis();\n            \n            lenis.on('scroll', ScrollTrigger.update);\n            \n            gsap.ticker.add((time) => {\n                lenis.raf(time * 1000);\n            });\n            \n            gsap.ticker.lagSmoothing(0);\n\n            // 2. Register Plugin\n            gsap.registerPlugin(ScrollTrigger);\n\n            // 3. Selection & Setup\n            const spotlightSection = document.querySelector(\".spotlight\");\n            const projectIndexElement = document.querySelector(\".project-index h1\");\n            const projectImgs = document.querySelectorAll(\".project-img\");\n            const projectImagesContainer = document.querySelector(\".project-images\");\n            const projectNames = document.querySelectorAll(\".project-names p\");\n            const projectNamesContainer = document.querySelector(\".names-wrapper\"); // inner wrapper needed for transform\n            \n            // This is just structural - typically one wrapper moves inside container\n            // For pixel perfect replication of tutorial logic where they calculate offsetHeight:\n            // We usually move the parent container if elements are static inside it\n            \n            const totalProjectCount = projectNames.length;\n\n            // Initial counter set\n            projectIndexElement.textContent = `01/${String(totalProjectCount).padStart(2, \"0\")}`;\n\n            // 4. Calculations for movement limits\n            \n            // To simulate \"scrubbing\" through the entire stack, we need a scroll distance\n            // usually calculated based on number of items * spacing + visual buffers\n            // However, since we want manual control inside onUpdate as per tutorial pattern:\n            \n            const calculateLayout = () => {\n                // Determine heights for layout math\n                const sectionHeight = spotlightSection.offsetHeight;\n                const sectionPadding = parseFloat(getComputedStyle(spotlightSection).paddingTop);\n                \n                // Ranges\n                // The images travel from mostly below view to mostly above view\n                const imagesHeight = projectImagesContainer.offsetHeight;\n                const moveDistanceImages = window.innerHeight - imagesHeight;\n                \n                // Names move inversely or in sync depending on design preference\n                const namesHeight = projectNamesContainer.offsetHeight;\n                \n                // Note: The specific variable names `moveDistanceIndex` from your snippet imply:\n                // distance = availableSpace - actualHeight\n                const moveDistanceNames = Math.max(0, namesHeight - 50); // Small movement\n                \n                // Activation threshold is exactly middle of screen\n                const imgActivationThreshold = window.innerHeight / 2;\n\n                return { moveDistanceImages, imgActivationThreshold, moveDistanceNames };\n            };\n\n            let { moveDistanceImages, imgActivationThreshold, moveDistanceNames } = calculateLayout();\n\n            // Recalc on resize\n            window.addEventListener('resize', () => {\n                const layout = calculateLayout();\n                moveDistanceImages = layout.moveDistanceImages;\n                imgActivationThreshold = layout.imgActivationThreshold;\n                moveDistanceNames = layout.moveDistanceNames;\n                ScrollTrigger.refresh();\n            });\n\n            // 5. ScrollTrigger Animation creation\n            \n            ScrollTrigger.create({\n                trigger: \".spotlight\",\n                start: \"top top\",\n                // Scroll distance multiplier - how long the pinned section lasts\n                // e.g., Height of viewport * number of items (reduced by factor 5 for speed in tutorial style)\n                end: `+=${window.innerHeight * 5}px`, \n                pin: true,\n                pinSpacing: true,\n                scrub: 1, // Smooth scrub\n                onUpdate: (self) => {\n                    const progress = self.progress;\n\n                    // A. Calculate Current Index\n                    // Map progress (0-1) to indices (1 to 10)\n                    // clamp values between 0 and total-1 for arrays, +1 for display\n                    let rawIndex = Math.floor(progress * totalProjectCount);\n                    // Constraint limits\n                    rawIndex = Math.min(rawIndex, totalProjectCount - 1);\n                    const currentIndex = rawIndex + 1;\n\n                    // Update Text Counter\n                    projectIndexElement.textContent = `${String(currentIndex).padStart(2, \"0\")}/${String(totalProjectCount).padStart(2, \"0\")}`;\n\n                    // B. Move Images Stack\n                    // Move the container up based on scroll progress\n                    gsap.set(projectImagesContainer, {\n                        y: progress * moveDistanceImages\n                    });\n\n                    // C. Highlight Active Image & Name\n                    projectImgs.forEach((imgWrapper, index) => {\n                        const img = imgWrapper.querySelector(\"img\");\n                        \n                        // We must get the Bounding Box relative to viewport *during* animation\n                        const rect = imgWrapper.getBoundingClientRect();\n                        const imgCenter = rect.top + (rect.height / 2);\n                        \n                        // Check if center of image is near the threshold center of screen\n                        // Tutorial often uses a simple bounds check: top <= center && bottom >= center\n                        \n                        const imgTop = rect.top;\n                        const imgBottom = rect.bottom;\n\n                        let isActive = false;\n                        \n                        // Logic from the provided snippets:\n                        // \"if (imgTop <= imgActivationThreshold && imgBottom >= imgActivationThreshold)\"\n                        if (imgTop <= imgActivationThreshold && imgBottom >= imgActivationThreshold) {\n                            isActive = true;\n                        }\n\n                        // Apply Styles\n                        if (isActive) {\n                            gsap.set(imgWrapper, { opacity: 1 });\n                            gsap.set(projectNames[index], { color: \"#fff\" });\n                        } else {\n                            gsap.set(imgWrapper, { opacity: 0.5 });\n                            gsap.set(projectNames[index], { color: \"#4a4a4a\" });\n                        }\n                    });\n\n                    // D. Move/Animate Project Names List (optional micro interaction)\n                    // The tutorial creates a \"sliding window\" effect for names based on active index\n                    // We calculate where the names list should be.\n                    // This logic shifts the names list so the active name stays roughly centered or in view\n                    \n                    const nameScrollRange = projectNamesContainer.scrollHeight - 100; // rough window height\n                    \n                    // Simple logic: Scroll list proportional to global progress\n                    // gsap.set(\".project-names\", { // Wrapper\n                    //    y: - (progress * moveDistanceNames) \n                    // });\n                    \n                    // Specific logic found in your text prompt analysis:\n                    // `y: -projectProgress * moveDistanceNames` where projectProgress was normalized\n                    // Since standard CSS flex-end stacking does heavy lifting here, \n                    // often the names container doesn't need aggressive translation if styling is right.\n                    // However, strictly adhering to the \"Scroll sync\" vibe:\n                    \n                    const nameStep = 1 / totalProjectCount;\n                    // For the 'stepping' visual where names move up\n                    const translateYNames = -(progress * (projectNamesContainer.offsetHeight * 0.5)); // Move somewhat up\n                    // Or static per design? In screenshot 13:04, names are static stack.\n                    // But `gsap.set(p, { y: ... })` was referenced in code analysis logic.\n                    // To keep pixel perfect to the visible behavior: Let the stack sit there, just highlight.\n                    \n                    // If detailed specific text scrolling was in tutorial logic:\n                    // We stick to the provided snippets logic for Names calculation\n                    // Snippet 12:49: \"gsap.set(projectNamesContainer, { y: progress * moveDistanceNames })\" logic\n                    // However, simpler is usually better here unless explicit math provided.\n                    // I will execute visual highlights which is core behavior.\n                }\n            });\n        });\n    </script>\n</body>\n</html>"
}