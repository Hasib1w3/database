{
  "title": "Animated Gradient Design 2",
  "description": "Animated Gradient Design minimalist 2",
  "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Animated Gradient</title>\n    <style>\n        body, html {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            background-color: #ebf0f7;\n        }\n\n        .canvas-container {\n            width: 100vw;\n            height: 100vh;\n            position: relative;\n        }\n\n        svg {\n            display: block;\n            width: 100%;\n            height: 100%;\n        }\n\n        /* \n           CSS Animation for the background light wash \n           shifts the vignette slightly \n        */\n        @keyframes subtle-shift {\n            0%, 100% { transform: scale(1.0); }\n            50% { transform: scale(1.1); }\n        }\n\n        .background-wash {\n            animation: subtle-shift 15s ease-in-out infinite;\n            transform-origin: center;\n        }\n    </style>\n</head>\n<body>\n\n<div class=\"canvas-container\">\n    <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1000 600\" preserveAspectRatio=\"xMidYMid slice\">\n        \n        <defs>\n            <!-- === 1. Static Texture (Unchanged) === -->\n            <filter id=\"paper-noise\" x=\"0%\" y=\"0%\" width=\"100%\" height=\"100%\">\n                <feTurbulence type=\"fractalNoise\" baseFrequency=\"0.80\" numOctaves=\"3\" stitchTiles=\"stitch\" result=\"noise\"/>\n                <feColorMatrix type=\"saturate\" values=\"0\" in=\"noise\" result=\"desaturatedNoise\"/>\n                <feComponentTransfer in=\"desaturatedNoise\" result=\"theNoise\">\n                     <!-- Slope adjusts the intensity of the grain -->\n                     <feFuncA type=\"linear\" slope=\"0.5\" /> \n                </feComponentTransfer>\n                <feBlend in=\"SourceGraphic\" in2=\"theNoise\" mode=\"overlay\" />\n            </filter>\n\n            <!-- === 2. Blurs === -->\n            <filter id=\"soft-blur\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n                <feGaussianBlur stdDeviation=\"60\" result=\"blur\"/>\n            </filter>\n             <filter id=\"medium-blur\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n                <feGaussianBlur stdDeviation=\"35\" result=\"blur\"/>\n            </filter>\n\n            <!-- === 3. Gradients === -->\n            <linearGradient id=\"grad-shadow\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n                <stop offset=\"0%\" stop-color=\"#bac6df\" stop-opacity=\"0.85\"/> \n                <stop offset=\"60%\" stop-color=\"#9eaec9\" stop-opacity=\"0.95\"/>\n                <stop offset=\"100%\" stop-color=\"#d3dcf2\" stop-opacity=\"0\"/>\n            </linearGradient>\n\n            <linearGradient id=\"grad-highlight\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\">\n                <stop offset=\"0%\" stop-color=\"#ffffff\" stop-opacity=\"0.9\"/>\n                <stop offset=\"100%\" stop-color=\"#f0f6ff\" stop-opacity=\"0.1\"/>\n            </linearGradient>\n            \n            <radialGradient id=\"grad-global\" cx=\"80%\" cy=\"20%\" r=\"90%\">\n                <stop offset=\"0%\" stop-color=\"#ffffff\" stop-opacity=\"0.6\"/>\n                <stop offset=\"100%\" stop-color=\"#e0e8f7\" stop-opacity=\"0.0\"/>\n            </radialGradient>\n        </defs>\n\n        <!-- === Layer 1: Base & Vignette === -->\n        <rect width=\"100%\" height=\"100%\" fill=\"#eff4fb\"/>\n        <rect width=\"1000\" height=\"600\" fill=\"url(#grad-global)\" class=\"background-wash\" opacity=\"0.8\"/>\n\n\n        <!-- === Layer 2: Animated Shadow Wave (The Deep Fold) === -->\n        <!-- We use SVG animate (SMIL) to morph the 'd' attribute. \n             This creates the organic \"liquid\" movement. -->\n        <path fill=\"url(#grad-shadow)\" filter=\"url(#soft-blur)\" opacity=\"0.8\">\n            <animate \n                attributeName=\"d\" \n                dur=\"8s\" \n                repeatCount=\"indefinite\" \n                values=\"\n                    M-150,-150 L500,-150 Q300,200 650,800 L-150,800 Z;\n                    M-150,-150 L400,-150 Q450,350 750,800 L-150,800 Z;\n                    M-150,-150 L500,-150 Q300,200 650,800 L-150,800 Z\"\n                calcMode=\"spline\" \n                keySplines=\"0.4 0 0.2 1; 0.4 0 0.2 1\"\n            />\n        </path>\n\n        <!-- === Layer 3: Secondary Corner Shadow === -->\n        <path fill=\"#cdd8ed\" opacity=\"0.6\" filter=\"url(#soft-blur)\">\n            <animate \n                attributeName=\"d\" \n                dur=\"11s\" \n                repeatCount=\"indefinite\" \n                values=\"\n                    M0,0 Q200,300 150,800 L0,800 Z;\n                    M0,0 Q350,250 100,800 L0,800 Z;\n                    M0,0 Q200,300 150,800 L0,800 Z\"\n            />\n        </path>\n\n        <!-- === Layer 4: The White Highlight Streak (The Crest) === -->\n        <!-- Moving slightly faster/different rhythm than the shadow for complexity -->\n        <path stroke=\"white\" stroke-width=\"80\" fill=\"none\" filter=\"url(#medium-blur)\" opacity=\"0.75\">\n             <animate \n                attributeName=\"d\" \n                dur=\"7s\" \n                repeatCount=\"indefinite\"\n                values=\"\n                    M250,-50 Q260,300 600,650;\n                    M300,-50 Q450,400 550,650;\n                    M250,-50 Q260,300 600,650\"\n                calcMode=\"spline\" \n                keySplines=\"0.4 0 0.2 1; 0.4 0 0.2 1\"\n            />\n        </path>\n\n        <!-- === Layer 5: Broad White Fill for Depth === -->\n        <path fill=\"white\" opacity=\"0.4\" filter=\"url(#soft-blur)\">\n            <animate \n                attributeName=\"d\" \n                dur=\"9s\" \n                repeatCount=\"indefinite\"\n                values=\"\n                    M250,-100 Q280,250 650,750 L1200,750 L1200,-100 Z;\n                    M350,-100 Q400,350 700,750 L1200,750 L1200,-100 Z;\n                    M250,-100 Q280,250 650,750 L1200,750 L1200,-100 Z\"\n            />\n        </path>\n\n\n        <!-- === Layer 6: TEXTURE (NOISE) === -->\n        <!-- This is a fixed rect on top. The turbulence inside does not move, \n             but the layers underneath animate, creating the desired effect. -->\n        <rect width=\"100%\" height=\"100%\" fill=\"transparent\" filter=\"url(#paper-noise)\" style=\"pointer-events: none;\"/>\n        \n        <!-- === Layer 7: Final Vignette === -->\n        <foreignObject width=\"100%\" height=\"100%\" style=\"pointer-events:none\">\n            <div style=\"\n                width: 100%; height: 100%; \n                background: radial-gradient(circle at 60% 40%, transparent 50%, rgba(130, 140, 170, 0.1) 110%);\n            \"></div>\n        </foreignObject>\n\n    </svg>\n</div>\n\n</body>\n</html>"
}