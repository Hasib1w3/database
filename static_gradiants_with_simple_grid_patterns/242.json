{
  "title": "Pattern 1",
  "description": "",
  "code": "<div class=\"bg\" aria-hidden=\"true\">\n  <style>\n/* Page baseline */\r\n  html,body{height:100%}\r\n  body{\r\n    margin:0;\r\n    background:#ffffff;\r\n    overflow:hidden; /* keep the ellipse clean */\r\n  }\r\n\r\n  /* Background wrapper */\r\n  .bg{\r\n    position:relative;\r\n    width:100%;\r\n    height:100vh;\r\n  }\r\n\r\n  /* Golden glow ellipse */\r\n  .glow{\r\n    position:absolute;\r\n    left:50%;\r\n    top:-280px;\r\n    transform:translateX(-50%);\r\n    width:1720px;\r\n    height:920px;\r\n    pointer-events:none;\r\n    z-index:0;\r\n\r\n    background:\r\n      radial-gradient(1200px 520px at 50% 0%,\r\n        rgba(255,255,255,1) 0%,\r\n        rgba(255,255,255,.98) 6%,\r\n        rgba(255,255,255,.92) 10%,\r\n        rgba(255,255,255,0) 12%),\r\n      radial-gradient(1200px 520px at 50% 0%,\r\n        rgba(244,197,91,.96) 0%,\r\n        rgba(244,197,91,.85) 16%,\r\n        rgba(244,197,91,.55) 36%,\r\n        rgba(244,197,91,.28) 55%,\r\n        rgba(244,197,91,.14) 66%,\r\n        rgba(244,197,91,0) 86%);\r\n    background-repeat:no-repeat,no-repeat;\r\n    background-position:center top, center top;\r\n    background-size:100% 100%,100% 100%;\r\n  }\r\n\r\n  /* Fine grain texture clipped to ellipse */\r\n  .grain{\r\n    position:absolute;\r\n    left:50%;\r\n    top:-280px;\r\n    transform:translateX(-50%);\r\n    width:1720px;\r\n    height:920px;\r\n    pointer-events:none;\r\n    z-index:1;\r\n\r\n    background-image:url(\"data:image/svg+xml;utf8,\\\r\n<svg xmlns='http://www.w3.org/2000/svg' width='220' height='220' viewBox='0 0 220 220' preserveAspectRatio='none'>\\\r\n  <filter id='n'>\\\r\n    <feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/>\\\r\n    <feColorMatrix type='saturate' values='0'/>\\\r\n  </filter>\\\r\n  <rect width='100%' height='100%' filter='url(%23n)' opacity='0.35'/>\\\r\n</svg>\");\r\n    background-size:220px 220px;\r\n    background-repeat:repeat;\r\n\r\n    -webkit-mask-image: radial-gradient(1200px 520px at 50% 0%,\r\n        rgba(0,0,0,1) 0%,\r\n        rgba(0,0,0,1) 64%,\r\n        rgba(0,0,0,.8) 72%,\r\n        rgba(0,0,0,.35) 80%,\r\n        rgba(0,0,0,0) 90%);\r\n            mask-image: radial-gradient(1200px 520px at 50% 0%,\r\n        rgba(0,0,0,1) 0%,\r\n        rgba(0,0,0,1) 64%,\r\n        rgba(0,0,0,.8) 72%,\r\n        rgba(0,0,0,.35) 80%,\r\n        rgba(0,0,0,0) 90%);\r\n    mix-blend-mode:multiply;\r\n    opacity:.55;\r\n  }\r\n\r\n  /* Optional: responsive tuning for smaller widths */\r\n  @media (max-width:980px){\r\n    .glow,.grain{\r\n      width:1400px; height:820px; top:-260px;\r\n      -webkit-mask-image: radial-gradient(980px 460px at 50% 0%, rgba(0,0,0,1) 0%, rgba(0,0,0,1) 65%, rgba(0,0,0,0) 88%);\r\n              mask-image: radial-gradient(980px 460px at 50% 0%, rgba(0,0,0,1) 0%, rgba(0,0,0,1) 65%, rgba(0,0,0,0) 88%);\r\n    }\r\n  }\n  </style>\n  <div class=\"glow\"></div>\n  <div class=\"grain\"></div>\n</div>"
}