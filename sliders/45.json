{
  "title": "PRODUCT SLIDER SVG MORPH OVERLAY",
  "code": {
    "index.html": "<!DOCTYPE html>\n<html>\n  <head>\n    <title>Classic Cuve - Product Page</title>\n    <meta charset=\"UTF-8\" />\n    <link rel=\"stylesheet\" href=\"styles.css\" />\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.11.5/gsap.min.js\"></script>\n  </head>\n  <body>\n    <div class=\"container\">\n      <nav>\n        <div id=\"logo\">Val Doca</div>\n        <div id=\"toggleOverlay\">Catalog</div>\n      </nav>\n      <div class=\"title\">Classic Cuvées</div>\n    </div>\n    <div class=\"wines\">\n      <div class=\"wrapper\">\n        <svg\n          class=\"transition\"\n          viewBox=\"0 0 100 100\"\n          preserveAspectRatio=\"none\"\n        >\n          <path\n            class=\"path\"\n            stroke=\"#36301D\"\n            fill=\"#36301D\"\n            stroke-width=\"2px\"\n            dur=\"10s\"\n            vector-effect=\"non-scaling-stroke\"\n            d=\"M 0 100 V 100 Q 50 100 100 100 V 100 z\"\n          />\n          <animateMotion dur=\"10s\" repeatCount=\"indefinite\">\n            <mpath xlink:href=\"#path\" />\n          </animateMotion>\n\n          <div id=\"wrap\">\n            <div class=\"block\">\n              <div class=\"product\">\n                <img src=\"./wines/wine-1.png\" alt=\"\" />\n              </div>\n            </div>\n            <div class=\"block\">\n              <div class=\"product\">\n                <img src=\"./wines/wine-2.png\" alt=\"\" />\n              </div>\n            </div>\n            <div class=\"block\">\n              <div class=\"product\">\n                <img src=\"./wines/wine-3.png\" alt=\"\" />\n              </div>\n            </div>\n            <div class=\"block\">\n              <div class=\"product\">\n                <img src=\"./wines/wine-4.png\" alt=\"\" />\n              </div>\n            </div>\n          </div>\n        </svg>\n      </div>\n      <button id=\"closeBtn\">Close</button>\n    </div>\n\n    <script type=\"text/javascript\">\n      window.addEventListener(\"DOMContentLoaded\", function () {\n        var docWidth = document.body.clientWidth;\n        var wrap = document.querySelector(\"#wrap\");\n        var images = document.querySelectorAll(\"#wrap .block\");\n        var slidesWidth = wrap.clientWidth;\n        var currentOffset = 0;\n        var targetOffset = 0;\n        var isAnimating = false;\n\n        window.addEventListener(\"resize\", function () {\n          docWidth = document.body.clientWidth;\n          slidesWidth = wrap.clientWidth;\n        });\n\n        document.addEventListener(\"mousemove\", function (e) {\n          var mouseX = e.pageX;\n          targetOffset = -1 * ((mouseX / docWidth) * slidesWidth - mouseX / 2);\n          if (!isAnimating) {\n            requestAnimationFrame(updateOffset);\n          }\n        });\n\n        function updateOffset() {\n          isAnimating = true;\n          currentOffset = lerp(currentOffset, targetOffset, 0.075);\n          if (Math.abs(currentOffset - targetOffset) < 0.5) {\n            currentOffset = targetOffset;\n            isAnimating = false;\n          }\n          for (var i = 0; i < images.length; i++) {\n            images[i].style.webkitTransform =\n              \"translate3d(\" + currentOffset + \"px,0,0)\";\n            images[i].style.transform =\n              \"translate3d(\" + currentOffset + \"px,0,0)\";\n          }\n          if (isAnimating) {\n            requestAnimationFrame(updateOffset);\n          }\n        }\n\n        function lerp(a, b, t) {\n          return (1 - t) * a + t * b;\n        }\n      });\n\n      const tl = gsap.timeline({ paused: true });\n\n      let $path = document.querySelector(\".path\");\n\n      function showInfo() {\n        revealDescription();\n\n        const showBtn = document.getElementById(\"toggleOverlay\");\n        showBtn.onclick = function (e) {\n          tl.reversed(!tl.reversed());\n        };\n\n        const closeBtn = document.getElementById(\"closeBtn\");\n        closeBtn.onclick = function (e) {\n          tl.reversed(!tl.reversed());\n        };\n      }\n\n      showInfo();\n\n      function revealDescription() {\n        const start = \"M 0 100 V 50 Q 50 0 100 50 V 100 z\";\n        const end = \"M 0 100 V 0 Q 50 0 100 0 V 100 z\";\n        tl.to(\".wines\", 0.1, {\n          opacity: 1,\n          ease: \"power2.inOut\",\n        });\n\n        tl.to($path, 0.8, { attr: { d: start }, ease: Power3.easeIn }).to(\n          $path,\n          0.4,\n          { attr: { d: end }, ease: Power3.easeOut }\n        );\n\n        tl.from(\".block\", 1, {\n          clipPath: \"inset(0 100% 0 0)\",\n          // top: \"100%\",\n          ease: Power4.easeOut,\n\n          stagger: {\n            amount: 0.25,\n          },\n        });\n\n        tl.from(\n          \".product img\",\n          1,\n          {\n            scale: 3,\n            ease: Power4.easeOut,\n            stagger: {\n              amount: 0.25,\n            },\n          },\n          \"-=1.5\"\n        );\n\n        tl.from(\n          \"#closeBtn\",\n          1,\n          {\n            opacity: 0,\n            right: \"-25%\",\n            ease: \"power2.inOut\",\n          },\n          \"-=1\"\n        ).reverse();\n      }\n    </script>\n  </body>\n</html>\n",
    "styles.css": "* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n  cursor: pointer;\n}\n\nhtml,\nbody {\n  width: 100%;\n  height: 100vh;\n  background: #ffffff;\n  color: #36301d;\n  overflow: hidden;\n}\n\nnav {\n  position: fixed;\n  width: 100%;\n  padding: 2em;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  font-family: \"Neue World\";\n  color: #36301d;\n  font-size: 24px;\n  font-weight: 300;\n}\n\n.title {\n  width: 100%;\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  text-align: center;\n  font-family: \"Neue World\";\n  color: #36301d;\n  font-size: 10vw;\n  font-weight: 300;\n  z-index: 1;\n}\n\n.wines {\n  position: relative;\n  width: 100%;\n  height: 100vh;\n  opacity: 0;\n  pointer-events: none;\n  z-index: 2;\n}\n\n.wrapper > .transition {\n  position: absolute;\n  left: 0;\n  top: 0;\n  width: 100%;\n  height: 100%;\n  overflow: hidden;\n}\n\n#wrap {\n  position: absolute;\n  left: 25%;\n  width: 150%;\n  height: 100vh;\n  display: flex;\n  align-items: center;\n  margin: 0 25%;\n}\n\n.block {\n  position: relative;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  z-index: 2;\n  width: 400px;\n  height: 500px;\n  margin: 0 1em;\n  background: #2e2918;\n  overflow: clip;\n  clip-path: inset(0 0 0 0);\n}\n\n.product {\n  position: relative;\n  display: block;\n  width: 400px !important;\n  height: 500px !important;\n  height: auto;\n  z-index: 2;\n  padding: 4em;\n}\n\n.product img {\n  width: 100%;\n  height: 100%;\n  object-fit: contain;\n}\n\nbutton#closeBtn {\n  position: absolute;\n  top: 0;\n  right: 0;\n  background: none;\n  border: none;\n  outline: none;\n  padding: 2em;\n  font-family: \"Neue World\";\n  font-size: 20px;\n  font-weight: 300;\n  color: #ecaa5d;\n  cursor: pointer;\n  pointer-events: all !important;\n}\n\n@media (max-width: 768px) {\n  .title {\n    font-size: 42px;\n  }\n\n  .tagline {\n    font-size: 15px;\n  }\n\n  .outline {\n    width: 92%;\n  }\n}\n"
  }
}