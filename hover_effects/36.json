  "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>SVG Image Hover Effect</title>\n    \n    <!-- Load Font -->\n    <style>\n        @import url(\"https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap\");\n        /* Using Outfit as Google Sans serves similar geometric vibes and is public */\n    </style>\n\n    <style>\n        :root {\n            --card-1-stroke: #e67339;\n            --card-2-stroke: #a66363;\n            --card-3-stroke: #eb3828;\n            --card-4-stroke: #a6a09d;\n            --card-5-stroke: #99938a;\n            --card-6-stroke: #5f7c98;\n            --card-base-stroke: #e0e0e0;\n            --card-copy: #000;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: \"Outfit\", sans-serif;\n            background: #fff;\n        }\n\n        h1 {\n            font-size: clamp(2rem, 5vw, 7rem);\n            font-weight: 500;\n            line-height: 1.25;\n            letter-spacing: -0.05rem;\n        }\n\n        h3 {\n            font-size: clamp(1.25rem, 2.5vw, 3rem);\n            font-weight: 450;\n            line-height: 1.25;\n            letter-spacing: -0.025rem;\n        }\n\n        img, svg {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n        }\n\n        header, footer {\n            width: 100%;\n            padding: 15rem 2rem;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            text-align: center;\n        }\n\n        .row {\n            width: 100%;\n            padding: 0 1rem;\n            margin-bottom: 1rem;\n            display: flex;\n            gap: 1rem;\n        }\n\n        .card-container {\n            position: relative;\n            flex: 1;\n            aspect-ratio: 1;\n            border-radius: 1rem;\n            overflow: hidden;\n        }\n\n        .card-container .svg-stroke {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%) scale(1.5);\n            width: 100%;\n            height: 100%;\n        }\n\n        /* Unique stroke colors */\n        #card-1 .svg-stroke-1 svg path { stroke: var(--card-1-stroke); }\n        #card-2 .svg-stroke-1 svg path { stroke: var(--card-2-stroke); }\n        #card-3 .svg-stroke-1 svg path { stroke: var(--card-3-stroke); }\n        #card-4 .svg-stroke-1 svg path { stroke: var(--card-4-stroke); }\n        #card-5 .svg-stroke-1 svg path { stroke: var(--card-5-stroke); }\n        #card-6 .svg-stroke-1 svg path { stroke: var(--card-6-stroke); }\n\n        .card-container .svg-stroke-2 svg path {\n            stroke: var(--card-base-stroke);\n        }\n\n        .card-title {\n            position: absolute;\n            bottom: 2rem;\n            left: 2rem;\n            color: var(--card-copy);\n        }\n\n        .card-title .word {\n            will-change: transform;\n            /* Necessary for splitting logic styling */\n            display: inline-block;\n        }\n\n        @media (max-width: 1000px) {\n            .row {\n                flex-direction: column;\n            }\n            .card-title {\n                bottom: 1rem;\n                left: 1rem;\n            }\n        }\n    </style>\n\n    <!-- Import Map to handle bare module imports from CDNs -->\n    <script type=\"importmap\">\n    {\n        \"imports\": {\n            \"gsap\": \"https://cdn.jsdelivr.net/npm/gsap@3.12.5/index.js\",\n            \"lenis\": \"https://cdn.jsdelivr.net/npm/lenis@1.1.5/dist/lenis.mjs\"\n        }\n    }\n    </script>\n</head>\n<body>\n\n    <header>\n        <h1>The Hover State</h1>\n    </header>\n\n    <!-- Row 1 -->\n    <div class=\"row\">\n        <!-- Card 1 -->\n        <div class=\"card-container\" id=\"card-1\">\n            <div class=\"card-img\">\n                <!-- Using Unsplash for preview purposes -->\n                <img src=\"https://images.unsplash.com/photo-1618085222105-2074338e3dc9?q=80&w=2564&auto=format&fit=crop\" alt=\"Abstract\">\n            </div>\n            \n            <div class=\"svg-stroke svg-stroke-1\">\n                <svg width=\"2453\" height=\"2273\" viewBox=\"0 0 2453 2273\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M227.549 1818.76C227.549 1818.76 406.016 2207.75 569.049 2130.26C843.431 1999.85 -264.104 1002.3 262.552 918 792.849 773.647 2456.11 1342.05 2130.26 1885.43 9644 455.772 760.548 137.262C1342.05 -111.152 1663.5 2266.35 2209.55 1972.76C2755.6 1679.18 1536.63 384.467 1826.55 137.262C2013.5 -22.1463 2209.55 381.262 2209.55 381.262\" stroke=\"#FE5E41\" stroke-width=\"200\" stroke-linecap=\"round\"/>\n                </svg>\n            </div>\n            \n            <div class=\"svg-stroke svg-stroke-2\">\n                <svg width=\"2453\" height=\"2273\" viewBox=\"0 0 2453 2273\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M227.549 1818.76C227.549 1818.76 406.016 2207.75 569.049 2130.26C843.431 1999.85 -264.104 1002.3 262.552 918 792.849 773.647 2456.11 1342.05 2130.26 1885.43 9644 455.772 760.548 137.262C1342.05 -111.152 1663.5 2266.35 2209.55 1972.76C2755.6 1679.18 1536.63 384.467 1826.55 137.262C2013.5 -22.1463 2209.55 381.262 2209.55 381.262\" stroke=\"#FE5E41\" stroke-width=\"200\" stroke-linecap=\"round\"/>\n                </svg>\n            </div>\n\n            <div class=\"card-title\">\n                <h3>Synthetic Silhouette</h3>\n            </div>\n        </div>\n\n        <!-- Card 2 -->\n        <div class=\"card-container\" id=\"card-2\">\n            <div class=\"card-img\">\n                <img src=\"https://images.unsplash.com/photo-1550921762-c07a3479b19e?q=80&w=2576&auto=format&fit=crop\" alt=\"Model\">\n            </div>\n            \n            <div class=\"svg-stroke svg-stroke-1\">\n                <svg width=\"2250\" height=\"2535\" viewBox=\"0 0 2250 2535\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M1661.28 2255.51C1661.28 2255.51 2111.09 1960.37 1817.01 1944.47 1696.67 718.456 2870.17 499.781 2255.51 308.969 1719.17 2457.51 1613.83 2111.78 963.512 1766.05 313.198 427.949 2195.17 132.281 1455.51 513.198 514 1708.78 252.012 1437.81 -314.29 369.471 909.169 132.281 566.512 18.1772 401.672 244.781 193.012 244.781 193.012\" stroke=\"#6E44FF\" stroke-width=\"200\" stroke-linecap=\"round\"/>\n                </svg>\n            </div>\n            \n            <div class=\"svg-stroke svg-stroke-2\">\n                <svg width=\"2250\" height=\"2535\" viewBox=\"0 0 2250 2535\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M1661.28 2255.51C1661.28 2255.51 2111.09 1960.37 1817.01 1944.47 1696.67 718.456 2870.17 499.781 2255.51 308.969 1719.17 2457.51 1613.83 2111.78 963.512 1766.05 313.198 427.949 2195.17 132.281 1455.51 513.198 514 1708.78 252.012 1437.81 -314.29 369.471 909.169 132.281 566.512 18.1772 401.672 244.781 193.012 244.781 193.012\" stroke=\"#6E44FF\" stroke-width=\"200\" stroke-linecap=\"round\"/>\n                </svg>\n            </div>\n\n            <div class=\"card-title\">\n                <h3>Red Form Study</h3>\n            </div>\n        </div>\n    </div>\n\n    <!-- Row 2 -->\n    <div class=\"row\">\n        <!-- Card 3 -->\n        <div class=\"card-container\" id=\"card-3\">\n            <div class=\"card-img\">\n                <img src=\"https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=2564&auto=format&fit=crop\" alt=\"Abstract\">\n            </div>\n            <div class=\"svg-stroke svg-stroke-1\">\n                <svg width=\"2453\" height=\"2273\" viewBox=\"0 0 2453 2273\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M227.549 1818.76C227.549 1818.76 406.016 2207.75 569.049 2130.26C843.431 1999.85 -264.104 1002.3 262.552 918 792.849 773.647 2456.11 1342.05 2130.26 1885.43 9644 455.772 760.548 137.262C1342.05 -111.152 1663.5 2266.35 2209.55 1972.76C2755.6 1679.18 1536.63 384.467 1826.55 137.262C2013.5 -22.1463 2209.55 381.262 2209.55 381.262\" stroke=\"#FE5E41\" stroke-width=\"200\" stroke-linecap=\"round\"/>\n                </svg>\n            </div>\n            <div class=\"svg-stroke svg-stroke-2\">\n                <svg width=\"2453\" height=\"2273\" viewBox=\"0 0 2453 2273\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M227.549 1818.76C227.549 1818.76 406.016 2207.75 569.049 2130.26C843.431 1999.85 -264.104 1002.3 262.552 918 792.849 773.647 2456.11 1342.05 2130.26 1885.43 9644 455.772 760.548 137.262C1342.05 -111.152 1663.5 2266.35 2209.55 1972.76C2755.6 1679.18 1536.63 384.467 1826.55 137.262C2013.5 -22.1463 2209.55 381.262 2209.55 381.262\" stroke=\"#FE5E41\" stroke-width=\"200\" stroke-linecap=\"round\"/>\n                </svg>\n            </div>\n            <div class=\"card-title\">\n                <h3>Obscured Profile</h3>\n            </div>\n        </div>\n\n        <!-- Card 4 -->\n        <div class=\"card-container\" id=\"card-4\">\n            <div class=\"card-img\">\n                <img src=\"https://images.unsplash.com/photo-1549416868-b7a426fa7aa2?q=80&w=2670&auto=format&fit=crop\" alt=\"Model\">\n            </div>\n            <div class=\"svg-stroke svg-stroke-1\">\n                <svg width=\"2250\" height=\"2535\" viewBox=\"0 0 2250 2535\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M1661.28 2255.51C1661.28 2255.51 2111.09 1960.37 1817.01 1944.47 1696.67 718.456 2870.17 499.781 2255.51 308.969 1719.17 2457.51 1613.83 2111.78 963.512 1766.05 313.198 427.949 2195.17 132.281 1455.51 513.198 514 1708.78 252.012 1437.81 -314.29 369.471 909.169 132.281 566.512 18.1772 401.672 244.781 193.012 244.781 193.012\" stroke=\"#6E44FF\" stroke-width=\"200\" stroke-linecap=\"round\"/>\n                </svg>\n            </div>\n            <div class=\"svg-stroke svg-stroke-2\">\n                <svg width=\"2250\" height=\"2535\" viewBox=\"0 0 2250 2535\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M1661.28 2255.51C1661.28 2255.51 2111.09 1960.37 1817.01 1944.47 1696.67 718.456 2870.17 499.781 2255.51 308.969 1719.17 2457.51 1613.83 2111.78 963.512 1766.05 313.198 427.949 2195.17 132.281 1455.51 513.198 514 1708.78 252.012 1437.81 -314.29 369.471 909.169 132.281 566.512 18.1772 401.672 244.781 193.012 244.781 193.012\" stroke=\"#6E44FF\" stroke-width=\"200\" stroke-linecap=\"round\"/>\n                </svg>\n            </div>\n            <div class=\"card-title\">\n                <h3>Material Pause</h3>\n            </div>\n        </div>\n    </div>\n\n    <!-- Row 3 -->\n    <div class=\"row\">\n        <!-- Card 5 -->\n        <div class=\"card-container\" id=\"card-5\">\n            <div class=\"card-img\">\n                <img src=\"https://images.unsplash.com/photo-1502163140606-888448ae8cdf?q=80&w=2670&auto=format&fit=crop\" alt=\"Abstract\">\n            </div>\n            <div class=\"svg-stroke svg-stroke-1\">\n                <svg width=\"2453\" height=\"2273\" viewBox=\"0 0 2453 2273\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M227.549 1818.76C227.549 1818.76 406.016 2207.75 569.049 2130.26C843.431 1999.85 -264.104 1002.3 262.552 918 792.849 773.647 2456.11 1342.05 2130.26 1885.43 9644 455.772 760.548 137.262C1342.05 -111.152 1663.5 2266.35 2209.55 1972.76C2755.6 1679.18 1536.63 384.467 1826.55 137.262C2013.5 -22.1463 2209.55 381.262 2209.55 381.262\" stroke=\"#FE5E41\" stroke-width=\"200\" stroke-linecap=\"round\"/>\n                </svg>\n            </div>\n            <div class=\"svg-stroke svg-stroke-2\">\n                <svg width=\"2453\" height=\"2273\" viewBox=\"0 0 2453 2273\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M227.549 1818.76C227.549 1818.76 406.016 2207.75 569.049 2130.26C843.431 1999.85 -264.104 1002.3 262.552 918 792.849 773.647 2456.11 1342.05 2130.26 1885.43 9644 455.772 760.548 137.262C1342.05 -111.152 1663.5 2266.35 2209.55 1972.76C2755.6 1679.18 1536.63 384.467 1826.55 137.262C2013.5 -22.1463 2209.55 381.262 2209.55 381.262\" stroke=\"#FE5E41\" stroke-width=\"200\" stroke-linecap=\"round\"/>\n                </svg>\n            </div>\n            <div class=\"card-title\">\n                <h3>Muted Presence</h3>\n            </div>\n        </div>\n\n        <!-- Card 6 -->\n        <div class=\"card-container\" id=\"card-6\">\n            <div class=\"card-img\">\n                <img src=\"https://images.unsplash.com/photo-1582299712079-994dfcb3ec44?q=80&w=2650&auto=format&fit=crop\" alt=\"Model\">\n            </div>\n            <div class=\"svg-stroke svg-stroke-1\">\n                <svg width=\"2250\" height=\"2535\" viewBox=\"0 0 2250 2535\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M1661.28 2255.51C1661.28 2255.51 2111.09 1960.37 1817.01 1944.47 1696.67 718.456 2870.17 499.781 2255.51 308.969 1719.17 2457.51 1613.83 2111.78 963.512 1766.05 313.198 427.949 2195.17 132.281 1455.51 513.198 514 1708.78 252.012 1437.81 -314.29 369.471 909.169 132.281 566.512 18.1772 401.672 244.781 193.012 244.781 193.012\" stroke=\"#6E44FF\" stroke-width=\"200\" stroke-linecap=\"round\"/>\n                </svg>\n            </div>\n            <div class=\"svg-stroke svg-stroke-2\">\n                <svg width=\"2250\" height=\"2535\" viewBox=\"0 0 2250 2535\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M1661.28 2255.51C1661.28 2255.51 2111.09 1960.37 1817.01 1944.47 1696.67 718.456 2870.17 499.781 2255.51 308.969 1719.17 2457.51 1613.83 2111.78 963.512 1766.05 313.198 427.949 2195.17 132.281 1455.51 513.198 514 1708.78 252.012 1437.81 -314.29 369.471 909.169 132.281 566.512 18.1772 401.672 244.781 193.012 244.781 193.012\" stroke=\"#6E44FF\" stroke-width=\"200\" stroke-linecap=\"round\"/>\n                </svg>\n            </div>\n            <div class=\"card-title\">\n                <h3>Spatial Balance</h3>\n            </div>\n        </div>\n    </div>\n\n    <footer>\n        <h1>End of Interaction</h1>\n    </footer>\n\n    <!-- Logic Script -->\n    <script type=\"module\">\n        import gsap from \"gsap\";\n        // Import a simulation of SplitText to function without the paid plugin for preview\n        import Lenis from \"lenis\";\n\n        /* \n           Simple SplitText Emulation\n           Since SplitText is a premium Club GSAP plugin, this basic emulator \n           is added so the requested \"Word splitting\" animation works \n           in a free/open file environment. \n        */\n        const SplitText = {\n            create: (target, vars) => {\n                const element = target;\n                const words = element.innerText.split(' ');\n                element.innerHTML = ''; // Clear text\n                \n                const spanWords = words.map(word => {\n                    const outerDiv = document.createElement('div');\n                    outerDiv.style.overflow = 'hidden';\n                    outerDiv.style.display = 'inline-block';\n                    outerDiv.style.marginRight = '0.25em';\n                    \n                    const innerDiv = document.createElement('div');\n                    innerDiv.className = 'word'; // Selector logic\n                    innerDiv.innerText = word;\n                    innerDiv.style.display = 'inline-block';\n                    \n                    outerDiv.appendChild(innerDiv);\n                    element.appendChild(outerDiv);\n                    \n                    return innerDiv; // Return the inner div that animates\n                });\n                \n                return { words: spanWords };\n            }\n        };\n\n        const lenis = new Lenis();\n        function raf(time) {\n            lenis.raf(time);\n            requestAnimationFrame(raf);\n        }\n        requestAnimationFrame(raf);\n\n        const cardContainers = document.querySelectorAll(\".card-container\");\n\n        cardContainers.forEach((cardContainer) => {\n            const cardPaths = cardContainer.querySelectorAll(\".svg-stroke path\");\n            const cardTitle = cardContainer.querySelector(\".card-title h3\");\n\n            // Split the text using our emulation/utility\n            const split = SplitText.create(cardTitle, {\n                type: \"words\",\n                mask: \"words\"\n            });\n\n            // Initial Set: Words hidden (yPercent: 100)\n            gsap.set(split.words, { yPercent: 100 });\n\n            // Prepare paths: hide them via dash offset\n            cardPaths.forEach((path) => {\n                const length = path.getTotalLength();\n                path.style.strokeDasharray = length;\n                path.style.strokeDashoffset = length;\n            });\n\n            let tl;\n\n            cardContainer.addEventListener(\"mouseenter\", () => {\n                if (tl) tl.kill();\n                tl = gsap.timeline();\n\n                // 1. Animate strokes (Drawing effect + getting thicker)\n                cardPaths.forEach((path) => {\n                    const length = path.getTotalLength();\n                    tl.to(\n                        path,\n                        {\n                            strokeDashoffset: 0,\n                            attr: { \"stroke-width\": 700 }, // Expands to fill\n                            duration: 1.5,\n                            ease: \"power2.out\",\n                        },\n                        0 // Start together\n                    );\n                });\n\n                // 2. Animate Title In (Staggered words)\n                tl.to(\n                    split.words,\n                    {\n                        yPercent: 0,\n                        duration: 0.75,\n                        ease: \"power3.out\",\n                        stagger: 0.075,\n                    },\n                    0.35 // Small delay relative to strokes\n                );\n            });\n\n            cardContainer.addEventListener(\"mouseleave\", () => {\n                if (tl) tl.kill();\n                tl = gsap.timeline();\n\n                // 1. Reverse strokes (Un-draw + get thin)\n                cardPaths.forEach((path) => {\n                    const length = path.getTotalLength();\n                    tl.to(\n                        path,\n                        {\n                            strokeDashoffset: length,\n                            attr: { \"stroke-width\": 200 }, // Reset width\n                            duration: 1,\n                            ease: \"power2.out\",\n                        },\n                        0\n                    );\n                });\n\n                // 2. Animate Title Out (Downwards)\n                tl.to(\n                    split.words,\n                    {\n                        yPercent: 100,\n                        duration: 0.5,\n                        ease: \"power3.out\",\n                        stagger: { each: 0.05, from: \"end\" },\n                    },\n                    0\n                );\n            });\n        });\n    </script>\n</body>\n</html>"
}