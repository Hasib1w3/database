    "index.html": "<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>minimal hovers</title>\n    <link rel=\"stylesheet\" href=\"styles.css\" />\n  </head>\n  <body>\n    <nav id=\"nav\">\n      <a href=\"#\">\n        <span>Oceanic</span>\n        <div class=\"img-wrapper\">\n          <img\n            src=\"https://images.unsplash.com/photo-1631468973194-f9ae0b52900b?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=1031&q=80\"\n          />\n        </div>\n      </a>\n      <a href=\"#\">\n        <span>Serenity</span>\n        <div class=\"img-wrapper\">\n          <img\n            src=\"https://images.unsplash.com/photo-1668081177040-3d6a3eaf2218?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=2835&q=80\"\n          />\n        </div>\n      </a>\n      <a href=\"#\">\n        <span>Zen</span>\n        <div class=\"img-wrapper\">\n          <img\n            src=\"https://images.unsplash.com/photo-1652129950700-8517fe5d068d?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=1064&q=80\"\n          />\n        </div>\n      </a>\n      <a href=\"#\">\n        <span>Ethereal</span>\n        <div class=\"img-wrapper\">\n          <img\n            src=\"https://images.unsplash.com/photo-1656702773363-989dec5bdd98?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=1064&q=80\"\n          />\n        </div>\n      </a>\n      <a href=\"#\">\n        <span>Blissful</span>\n        <div class=\"img-wrapper\">\n          <img\n            src=\"https://images.unsplash.com/photo-1647960792836-385e6daddfc1?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=1064&q=80\"\n          />\n        </div>\n  