   <span>Haven</span>\n        <div class=\"img-wrapper\">\n          <img\n            src=\"https://images.unsplash.com/photo-1653082379311-0e72bca7ddb2?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=1064&q=80\"\n          />\n        </div>\n      </a>\n      <a href=\"#\">\n        <span>Oasis</span>\n        <div class=\"img-wrapper\">\n          <img\n            src=\"https://images.unsplash.com/photo-1635987739727-11e2578bd0cc?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=654&q=80\"\n          />\n        </div>\n      </a>\n      <a href=\"#\">\n        <span>Vibrant</span>\n        <div class=\"img-wrapper\">\n          <img\n            src=\"https://images.unsplash.com/photo-1636207543865-acf3ad382295?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=2070&q=80\"\n          />\n        </div>\n      </a>\n      <a href=\"#\">\n        <span>Utopian</span>\n        <div class=\"img-wrapper\">\n          <img\n            src=\"https://images.unsplash.com/photo-1636601209939-ed803d732d0e?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=2000&q=80\"\n          />\n        </div>\n      </a>\n      <a href=\"#\">\n        <span>Auroral</span>\n        <div class=\"img-wrapper\">\n          <img\n            src=\"https://images.unsplash.com/photo-1599814733655-eb9434004bf8?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=774&q=80\"\n          />\n        </div>\n      </a>\n      <a href=\"#\">\n        <span>Halcyon</span>\n        <div class=\"img-wrapper\">\n          <img\n            src=\"https://images.unsplash.com/photo-1621797334469-74c5fa26df05?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=774&q=80\"\n          />\n        </div>\n      </a>\n      <a href=\"#\">\n        <span>Dreamy</span>\n        <div class=\"img-wrapper\">\n          <img\n            src=\"https://images.unsplash.com/photo-1634717737934-c9dab44369ef?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=1180&q=80\"\n          />\n        </div>\n      </a>\n      <a href=\"#\">\n        <span>Luminous</span>\n        <div class=\"img-wrapper\">\n          <img\n            src=\"https://images.unsplash.com/photo-1633355066285-7101d2a2d047?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=790&q=80\"\n          />\n        </div>\n      </a>\n      <a href=\"#\">\n        <span>Eden</span>\n        <div class=\"img-wrapper\">\n          <img\n            src=\"https://images.unsplash.com/photo-1656060791456-86315c1ce617?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=996&q=80\"\n          />\n        </div>\n      </a>\n      <a href=\"#\">\n        <span>Felicity</span>\n        <div class=\"img-wrapper\">\n          <img\n            src=\"https://images.unsplash.com/photo-1655374631048-1416d81cd20a?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=996&q=80\"\n          />\n        </div>\n      </a>\n      <a href=\"#\">\n        <span>Aspiring</span>\n        <div class=\"img-wrapper\">\n          <img\n            src=\"https://images.unsplash.com/photo-1632059368252-be6d65abc4e2?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=1770&q=80\"\n          />\n        </div>\n      </a>\n      <a href=\"#\">\n        <span>Elated</span>\n        <div class=\"img-wrapper\">\n          <img\n            src=\"https://images.unsplash.com/photo-1660823735684-bc2f774b2642?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=870&q=80\"\n          />\n        </div>\n      </a>\n      <a href=\"#\">\n        <span>Nirvana</span>\n        <div class=\"img-wrapper\">\n          <img\n            src=\"https://images.unsplash.com/photo-1633153010796-6cf54b5daebb?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=928&q=80\"\n          />\n        </div>\n      </a>\n    </nav>\n    <script src=\"./script.js\"></script>\n  </body>\n</html>\n",
    "script.js": "const nav = document.getElementById(\"nav\");\n\nfor (const link of nav.getElementsByTagName(\"a\")) {\n  link.onmousemove = (e) => {\n    const rect = link.getBoundingClientRect(),\n      img = link.querySelector(\"img\");\n\n    //     img.style.left = `${e.clientX - rect.left}px`;\n    //     img.style.top = `${e.clientY - rect.top}px`;\n  };\n}\n\nwindow.onmousemove = (e) => {\n  const percent = e.clientX / window.innerWidth;\n\n  nav.animate(\n    {\n      transform: `translateX(${percent * nav.offsetWidth * -1}px)`,\n    },\n    {\n      fill: \"forwards\",\n      duration: 4000,\n    }\n  );\n};\n",
    "styles.css": "* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nbody {\n  background-color: #fff;\n  overflow: hidden;\n}\n\nnav {\n  position: absolute;\n  top: 40%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  display: flex;\n  flex-direction: row;\n}\n\nnav > a {\n  color: rgb(184, 184, 184);\n  font-family: \"Neue Montreal\", sans-serif;\n  text-decoration: none;\n  position: relative;\n  text-transform: uppercase;\n  padding: 2em 0.4em;\n  font-weight: 500;\n  mix-blend-mode: difference;\n  text-align: center;\n}\n\nnav > a:hover {\n  color: #fff;\n}\n\nnav > a > span {\n  position: relative;\n  z-index: 2;\n  width: 400px;\n}\n\nnav a .img-wrapper {\n  position: absolute;\n  opacity: 0;\n  transform: translate(-50%, -50%) scale(0.5);\n  transition: all 250ms;\n  pointer-events: none;\n  width: 300px;\n  height: 400px;\n  overflow: hidden;\n}\n\nnav a img {\n  position: absolute;\n  opacity: 0;\n  top: 0;\n  left: 0;\n  transform: scale(2.5);\n  transition: transform 2000ms cubic-bezier(0.075, 0.82, 0.165, 1.5),\n    opacity 250ms;\n  pointer-events: none;\n  width: 100%;\n  height: 100%;\n  object-fit: contain;\n}\n\nnav a:hover .img-wrapper {\n  opacity: 1;\n  transform: translate(-50%, -50%) scale(1);\n}\n\nnav a:hover img {\n  opacity: 1;\n  transform: scale(1.5);\n}\n"
  }
