{
  "title": "Glassy Button (Square, with Sound)",
  "description": "A glassy, square button with layered gradients, hover/active shadows, and an icon with subtle shadow. Includes click sound playback.",
  "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Glassy Button</title>\n    <style>\n        body {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            min-height: 100vh;\n            background-color: #f0f0f0;\n            margin: 0;\n        }\n\n        .glassy-button {\n            width: 149px;\n            height: 146px;\n            border-radius: 40px;\n            cursor: pointer;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            position: relative;\n            background: linear-gradient(180deg, rgb(255, 255, 255) 0%, rgb(201, 201, 201) 8.99%, rgb(161, 161, 161) 31.88%, rgb(117, 117, 117) 73%, rgb(255, 255, 255) 100%);\n            box-shadow: 0.07px 1.01px 0.5px 0px rgba(0, 0, 0, 0), 0.16px 2.39px 1.2px 0px rgba(0, 0, 0, 0), 0.29px 4.36px 2.18px 0px rgba(0, 0, 0, 0.01), 0.48px 7.24px 3.63px 0px rgba(0, 0, 0, 0.01), 0.78px 11.7px 5.86px 0px rgba(0, 0, 0, 0.02), 1.28px 19.15px 9.6px 0px rgba(0, 0, 0, 0.03), 2.2px 32.97px 16.52px 0px rgba(0, 0, 0, 0.05), 4px 60px 30.07px 0px rgba(0, 0, 0, 0.1);\n            transition: background 0.4s, box-shadow 0.4s;\n            padding: 3px;\n        }\n\n        .glassy-button:hover {\n            box-shadow: 0.07px 1.01px 0.5px 0px rgba(0, 0, 0, 0), 0.16px 2.39px 1.2px 0px rgba(0, 0, 0, 0), 0.29px 4.36px 2.18px 0px rgba(0, 0, 0, 0.01), 0.48px 7.24px 3.63px 0px rgba(0, 0, 0, 0.01), 0.78px 11.7px 5.86px 0px rgba(0, 0, 0, 0.01), 1.28px 19.15px 9.6px 0px rgba(0, 0, 0, 0.02), 2.2px 32.97px 16.52px 0px rgba(0, 0, 0, 0.04), 4px 60px 30.07px 0px rgba(0, 0, 0, 0.07);\n        }\n\n        .glassy-button:active {\n            box-shadow: 0.07px 1.01px 0.4px -0.375px rgba(0, 0, 0, 0.03), 0.16px 2.39px 0.96px -0.75px rgba(0, 0, 0, 0.03), 0.29px 4.36px 1.75px -1.125px rgba(0, 0, 0, 0.03), 0.48px 7.24px 2.9px -1.5px rgba(0, 0, 0, 0.03), 0.78px 11.7px 4.69px -1.875px rgba(0, 0, 0, 0.03), 1.28px 19.15px 7.68px -2.25px rgba(0, 0, 0, 0.03), 2.2px 32.97px 13.22px -2.625px rgba(0, 0, 0, 0.02), 4px 60px 24.05px -3px rgba(0, 0, 0, 0.02);\n        }\n        \n        .content {\n            flex: 1;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            border-radius: 37px;\n            background: linear-gradient(150deg, rgb(208, 208, 208) 0%, rgb(204, 204, 204) 50.17%, rgb(200, 200, 200) 100%);\n            width: 100%;\n            height: 100%;\n        }\n\n        .glassy-button:hover .content {\n             background: linear-gradient(150deg, rgb(208, 208, 208) 0%, rgb(232, 232, 232) 50.17%, rgb(200, 200, 200) 100%);\n        }\n\n        .icon-wrapper {\n            position: relative;\n            width: 68px;\n            height: 68px;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n\n        .icon {\n            position: absolute;\n            width: 96px;\n            height: 96px;\n            opacity: 1;\n            transition: opacity 0.4s;\n            z-index: 1;\n        }\n        \n        .glassy-button:active .icon {\n            opacity: 0.8;\n        }\n\n        .shadow {\n            position: absolute;\n            width: 96px;\n            height: 96px;\n            opacity: 0.4;\n            transform: translate(-50%, -50%) translate(53%, 54%);\n            transition: opacity 0.4s;\n        }\n\n    </style>\n</head>\n<body>\n\n    <div class=\"glassy-button\" onclick=\"playSound()\">\n        <div class=\"content\">\n            <div class=\"icon-wrapper\">\n                <svg class=\"icon\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M3 9L12 2L21 9V20C21 20.5304 20.7893 21.0391 20.4142 21.4142C20.0391 21.7893 19.5304 22 19 22H5C4.46957 22 3.96086 21.7893 3.58579 21.4142C3.21071 21.0391 3 20.5304 3 20V9Z\" stroke=\"rgb(0, 0, 0)\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                    <path d=\"M9 22V12H15V22\" stroke=\"rgb(0, 0, 0)\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                </svg>\n                 <svg class=\"shadow\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M3 9L12 2L21 9V20C21 20.5304 20.7893 21.0391 20.4142 21.4142C20.0391 21.7893 19.5304 22 19 22H5C4.46957 22 3.96086 21.7893 3.58579 21.4142C3.21071 21.0391 3 20.5304 3 20V9Z\" stroke=\"rgb(255, 255, 255)\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                    <path d=\"M9 22V12H15V22\" stroke=\"rgb(255, 255, 255)\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                </svg>\n            </div>\n        </div>\n    </div>\n    \n    <audio id=\"clickSound\" src=\"https://framerusercontent.com/assets/QftwjMR4j8LTgXvov8IGLNVxLS4.mp3\"></audio>\n\n    <script>\n        function playSound() {\n            const sound = document.getElementById('clickSound');\n            sound.currentTime = 0;\n            sound.play();\n        }\n    </script>\n\n</body>\n</html>"
}