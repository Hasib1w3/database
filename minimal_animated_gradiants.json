[
  {
    "title": "Animated Gradient Design",
    "description": "Animated Gradient Design minimalist",
    "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Animated Gradient Design</title>\n<style>\n    :root {\n        --bg-base: #dfe5ed;\n        --purple-tint: #b0b8d6;\n        --teal-hint: #d5e6eb;\n        --white-sheen: #ffffff;\n    }\n\n    body, html {\n        margin: 0;\n        padding: 0;\n        width: 100%;\n        height: 100%;\n        overflow: hidden;\n        background-color: var(--bg-base);\n    }\n\n    /* \n      1. BACKGROUND BLOBS \n      Broken apart so they can 'breathe' independently\n    */\n    .orb {\n        position: absolute;\n        border-radius: 50%;\n        filter: blur(80px); /* Heavy blur to blend them */\n        opacity: 0.8;\n        will-change: transform;\n    }\n\n    .orb-purple {\n        top: -10%;\n        left: -10%;\n        width: 60vw;\n        height: 60vh;\n        background: var(--purple-tint);\n        animation: float 14s ease-in-out infinite alternate;\n    }\n\n    .orb-teal {\n        bottom: 10%;\n        right: -10%;\n        width: 70vw;\n        height: 70vh;\n        background: var(--teal-hint);\n        animation: float-reverse 18s ease-in-out infinite alternate;\n    }\n\n    .orb-white {\n        bottom: -20%;\n        left: 20%;\n        width: 60vw;\n        height: 50vh;\n        background: var(--white-sheen);\n        opacity: 0.6;\n        animation: breathe 10s ease-in-out infinite alternate;\n    }\n\n    /* \n       2. THE FOLD GEOMETRY\n       Animated to sway like fabric\n    */\n    .fold-curve {\n        position: absolute;\n        top: -15%;\n        left: -20%;\n        width: 80%;\n        height: 130%;\n        background: linear-gradient(135deg, rgba(176, 184, 214, 0.4) 0%, rgba(255,255,255,0) 80%);\n        border-radius: 50% 20% / 10% 40%;\n        \n        /* Initial Position */\n        transform-origin: 50% 50%;\n        transform: rotate(15deg) translate(0, 0);\n        \n        box-shadow: 20px 0 60px rgba(255,255,255, 0.6);\n        z-index: 2;\n        \n        animation: sway-fold 12s ease-in-out infinite;\n    }\n\n    /* \n       3. THE CREASE LINE \n       Moves slightly differently to create 3D parallax depth\n    */\n    .fold-crease {\n        position: absolute;\n        top: -20%;\n        left: 28%;\n        width: 80%;\n        height: 140%;\n        background: radial-gradient(ellipse at left, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0) 30%, transparent 100%);\n        transform: rotate(25deg) skewX(-10deg);\n        filter: blur(25px);\n        z-index: 3;\n        opacity: 0.8;\n        \n        animation: shimmer-crease 15s ease-in-out infinite reverse;\n    }\n\n    /* \n       4. OVERHEAD HIGHLIGHT\n       A drifting light source\n    */\n    .highlight-overlay {\n        position: absolute;\n        width: 120%;\n        height: 120%;\n        top: -10%; \n        left: -10%;\n        background: conic-gradient(from 180deg at 50% -20%, transparent 40%, rgba(255,255,255,0.4) 50%, transparent 60%);\n        filter: blur(80px);\n        z-index: 4;\n        animation: rotate-light 20s ease-in-out infinite;\n    }\n\n    /* \n       5. NOISE OVERLAY\n       Kept STATIC. Moving this filter is too heavy on CPU \n       and hurts the aesthetic quality.\n    */\n    .noise-overlay {\n        position: fixed;\n        top: 0;\n        left: 0;\n        width: 100%;\n        height: 100%;\n        z-index: 999;\n        opacity: 0.7; /* Adjusted opacity for animation visibility */\n        filter: url(#grainy);\n        mix-blend-mode: overlay; \n        pointer-events: none;\n    }\n\n    /* ---- KEYFRAMES ---- */\n\n    @keyframes float {\n        0% { transform: translate(0px, 0px) scale(1); }\n        50% { transform: translate(50px, 50px) scale(1.1); }\n        100% { transform: translate(20px, 10px) scale(0.9); }\n    }\n\n    @keyframes float-reverse {\n        0% { transform: translate(0px, 0px); }\n        100% { transform: translate(-40px, -60px); }\n    }\n\n    @keyframes breathe {\n        0% { opacity: 0.4; transform: scale(0.8); }\n        100% { opacity: 0.7; transform: scale(1.1); }\n    }\n\n    @keyframes sway-fold {\n        0% { transform: rotate(15deg) translate(0px, 0px); border-radius: 50% 20% / 10% 40%;}\n        50% { transform: rotate(13deg) translate(-2%, 2%); border-radius: 55% 25% / 15% 45%;}\n        100% { transform: rotate(15deg) translate(0px, 0px); border-radius: 50% 20% / 10% 40%;}\n    }\n\n    @keyframes shimmer-crease {\n        0% { transform: rotate(25deg) skewX(-10deg) translateX(0); opacity: 0.8; }\n        50% { transform: rotate(26deg) skewX(-8deg) translateX(20px); opacity: 0.6; }\n        100% { transform: rotate(25deg) skewX(-10deg) translateX(0); opacity: 0.8; }\n    }\n\n    @keyframes rotate-light {\n        0% { transform: rotate(0deg) translate(0,0); }\n        50% { transform: rotate(3deg) translate(-20px, 20px); }\n        100% { transform: rotate(0deg) translate(0,0); }\n    }\n\n</style>\n</head>\n<body>\n\n    <!-- Background Layer (Broken into animated orbs) -->\n    <div class=\"orb orb-purple\"></div>\n    <div class=\"orb orb-teal\"></div>\n    <div class=\"orb orb-white\"></div>\n\n    <!-- Cloth Geometry -->\n    <div class=\"fold-curve\"></div>\n    <div class=\"fold-crease\"></div>\n    <div class=\"highlight-overlay\"></div>\n\n    <!-- Grain Layer -->\n    <div class=\"noise-overlay\"></div>\n\n    <!-- SVG Filter Definition -->\n    <svg style=\"display: none;\">\n        <defs>\n            <filter id=\"grainy\">\n                <feTurbulence type=\"fractalNoise\" baseFrequency=\"0.65\" numOctaves=\"3\" stitchTiles=\"stitch\" result=\"noise\"/>\n                <feColorMatrix type=\"saturate\" values=\"0\" in=\"noise\" result=\"monoNoise\"/>\n                <feColorMatrix type=\"matrix\" in=\"monoNoise\" values=\"\n                    0.5 0 0 0 0\n                    0 0.5 0 0 0\n                    0 0 0.5 0 0\n                    0 0 0 0.4 0\" />\n            </filter>\n        </defs>\n    </svg>\n\n</body>\n</html>"
  }
]