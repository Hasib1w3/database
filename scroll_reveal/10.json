{
  "title": "-",
  "description": "-",
  "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>JeskoJets Scroll Animation | CodeGrid Recreation</title>\n    \n    <!-- Google Fonts: Instrument Serif -->\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap\" rel=\"stylesheet\">\n\n    <style>\n        :root {\n            --light: #e3e3db;\n            --dark: #0f0f0f;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: \"Instrument Serif\", serif;\n            background-color: var(--light);\n            color: var(--dark);\n            /* Standard smooth scroll cleanup */\n            overscroll-behavior: none;\n        }\n\n        /* Responsive typography clamps */\n        h1 {\n            font-size: clamp(5rem, 6vw, 7rem);\n            font-weight: 500;\n            line-height: 0.8;\n        }\n\n        p {\n            font-size: 1.35rem;\n            line-height: 1;\n        }\n\n        /* Generic image handling */\n        img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            display: block;\n        }\n\n        section {\n            position: relative;\n            width: 100%;\n            height: 100svh;\n            overflow: hidden;\n        }\n\n        /* HERO SECTION */\n        .hero {\n            perspective: 1000px; /* Crucial for Z-axis text movement */\n        }\n\n        /* The moving sky background - taller than viewport for parallax */\n        .sky-container {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 350svh;\n            z-index: 1;\n            will-change: transform;\n        }\n\n        /* The big text that reveals at the end */\n        .hero-copy {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100svh;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            text-align: center;\n            z-index: 2; /* behind window but front of sky */\n            will-change: transform;\n        }\n\n        .hero-copy h1 {\n            width: 85%;\n            color: var(--dark);\n        }\n\n        /* The airplane window frame */\n        .window-container {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100svh;\n            z-index: 3;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            pointer-events: none; /* Let scroll pass through */\n            will-change: transform;\n        }\n        \n        .window-container img {\n            width: auto;\n            height: 100%;\n            object-fit: contain; \n        }\n\n        /* The foreground text overlaid on the window */\n        .hero-header {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100svh;\n            padding: 2rem;\n            display: flex;\n            justify-content: space-between;\n            z-index: 4;\n            transform-style: preserve-3d;\n            will-change: transform;\n            color: var(--light); \n        }\n\n        .hero-header .col {\n            flex: 1;\n            display: flex;\n            flex-direction: column;\n            justify-content: space-between;\n        }\n\n        .hero-header .col p {\n            width: 50%;\n        }\n\n        /* Right column alignment specific */\n        .hero-header .col:nth-child(2) {\n            align-items: flex-end;\n            text-align: right;\n        }\n\n        /* OUTRO SECTION (To create scrolling space after pin) */\n        .outro {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            background: var(--light);\n            padding: 2rem;\n        }\n\n        /* Small screens adjustments */\n        @media (max-width: 1000px) {\n            h1 { font-size: 3rem; }\n            p { font-size: 1.125rem; }\n        }\n    </style>\n</head>\n<body>\n\n    <!-- Main Animation Section -->\n    <section class=\"hero\">\n        \n        <!-- Layer 1: Background Sky -->\n        <div class=\"sky-container\">\n            <!-- Using a Unsplash placeholder for night clouds -->\n            <img src=\"https://images.unsplash.com/photo-1536746803623-4b07e1548e24?q=80&w=2674&auto=format&fit=crop\" alt=\"Night Sky\">\n        </div>\n\n        <!-- Layer 2: Final Text Reveal -->\n        <div class=\"hero-copy\">\n            <h1>What unfolds here is not a scene, but a duration. The frame holds steady while the world behind it shifts.</h1>\n        </div>\n\n        <!-- Layer 3: Airplane Window Frame -->\n        <div class=\"window-container\">\n            <!-- NOTE: Using a public URL for an airplane window frame PNG. -->\n            <img src=\"https://assets.codepen.io/1043445/airplane-window.png\" alt=\"Window Frame\">\n        </div>\n\n        <!-- Layer 4: Floating 3D Text Overlay -->\n        <div class=\"hero-header\">\n            <div class=\"col\">\n                <h1>An aperture <br /> into stillness</h1>\n                <p>A constructed moment, suspended between form and vastness. Light, surface and scale.</p>\n            </div>\n            <div class=\"col\">\n                <p>Observation Mode</p>\n                <h1>Where distance <br /> becomes presence</h1>\n            </div>\n        </div>\n\n    </section>\n\n    <!-- Content to scroll past afterwards -->\n    <section class=\"outro\">\n        <h1>End of view.</h1>\n    </section>\n\n    <!-- Dependencies -->\n    \n    <!-- FIXED: Correct CDN for Studio Freight Lenis V1 which supports new Lenis() -->\n    <script src=\"https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.42/dist/lenis.min.js\"></script>\n    \n    <!-- GSAP Core -->\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js\"></script>\n    <!-- ScrollTrigger Plugin -->\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js\"></script>\n\n    <script>\n        document.addEventListener(\"DOMContentLoaded\", () => {\n            \n            // 1. Register Plugins\n            gsap.registerPlugin(ScrollTrigger);\n\n            // 2. Initialize Lenis Smooth Scroll\n            const lenis = new Lenis({\n                duration: 1.2,\n                easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n                direction: 'vertical',\n                gestureDirection: 'vertical',\n                smooth: true,\n            });\n\n            // Connect Lenis to GSAP's ticker ensures sync\n            lenis.on('scroll', ScrollTrigger.update);\n\n            gsap.ticker.add((time) => {\n                lenis.raf(time * 1000);\n            });\n\n            gsap.ticker.lagSmoothing(0);\n\n            // 3. Select Elements\n            const windowContainer = document.querySelector(\".window-container\");\n            const skyContainer = document.querySelector(\".sky-container\");\n            const heroCopy = document.querySelector(\".hero-copy\");\n            const heroHeader = document.querySelector(\".hero-header\");\n\n            // 4. Initial Styles via GSAP (Set starting state)\n            // Push the final text copy down by 100% initially so it can slide up later\n            gsap.set(heroCopy, { yPercent: 100 });\n\n            // 5. Create the Scroll Animation\n            ScrollTrigger.create({\n                trigger: \".hero\",\n                start: \"top top\",\n                // This manually adds extra scroll distance (3x viewport height) to extend the duration\n                end: () => `+=${window.innerHeight * 3}px`, \n                pin: true,\n                pinSpacing: true,\n                scrub: 1, // Smooth interaction\n                onUpdate: (self) => {\n                    const progress = self.progress; // value 0 to 1\n                    \n                    const windowHeight = window.innerHeight;\n                    const skyHeight = skyContainer.offsetHeight;\n                    \n                    // -- ANIMATION LOGIC --\n\n                    // A. Move the sky vertically (Parallax)\n                    const moveDistance = skyHeight - windowHeight;\n                    gsap.set(skyContainer, { y: -progress * moveDistance });\n\n                    // B. Scale the Window (The \"Zoom In\" Effect)\n                    let windowScale = 1;\n                    \n                    if (progress <= 0.5) {\n                        // Normalize 0-0.5 to 0-1 range, multiply by desired zoom factor\n                        windowScale = 1 + (progress / 0.5) * 3; \n                    } else {\n                        // After 50% scroll, lock scale at 4\n                        windowScale = 4;\n                    }\n                    \n                    gsap.set(windowContainer, { scale: windowScale });\n\n                    // C. Animate the Header Text (Scale + 3D Movement)\n                    gsap.set(heroHeader, { \n                        scale: windowScale,\n                        z: progress * 500 // Move 500px \"closer\" to screen\n                    });\n\n                    // D. Reveal the Copy Text\n                    // Logic: Start revealing after 66% scroll completion\n                    let copyY = 100; // Start mostly hidden\n                    \n                    if (progress > 0.66) {\n                        const remainingProgress = (progress - 0.66) / 0.34; // Normalize to 0-1\n                        copyY = 100 * (1 - remainingProgress); // Map to 100->0\n                        \n                        if (copyY < 0) copyY = 0; \n                    }\n                    \n                    gsap.set(heroCopy, { yPercent: copyY });\n                }\n            });\n        });\n    </script>\n</body>\n</html>"
}